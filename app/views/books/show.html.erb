<% content_for :title, "#{@book.localized_title(I18n.locale)} · #{t('site.name')}" %>

<%# ─── Hero ─────────────────────────────────────────────────────────── %>
<section class="relative pt-36 pb-24 overflow-hidden bg-mesh">
  <div class="absolute -top-32 -left-32 size-[36rem] rounded-full bg-eco-green/10 blur-[140px] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 grid lg:grid-cols-12 gap-12 items-center">
    <%# Cover %>
    <div class="lg:col-span-5">
      <div class="relative max-w-md mx-auto eco-float">
        <img src="/source-assets/volume-<%= @book.volume_number %>.jpg"
             alt="<%= @book.localized_title(I18n.locale) %>"
             class="w-full border border-eco-border shadow-[0_60px_120px_-30px_rgba(163,191,100,0.3)]">
        <div class="absolute -top-5 -left-5 size-20 rounded-full border border-eco-green/40 bg-eco-bg/70 backdrop-blur-md flex items-center justify-center font-display italic text-3xl text-eco-green-light">
          <%= @book.volume_number == 1 ? "I" : "II" %>
        </div>
      </div>
    </div>

    <%# Copy %>
    <div class="lg:col-span-7 space-y-6" data-controller="reveal">
      <nav class="flex items-center gap-2 text-xs tracking-wider uppercase text-eco-text-muted">
        <%= link_to t("nav.home"), root_path, class: "hover:text-eco-green-light" %>
        <span>/</span>
        <%= link_to t("nav.volume_one").split.first, books_path, class: "hover:text-eco-green-light" %>
        <span>/</span>
        <span class="text-eco-green-light">Vol. <%= @book.volume_number %></span>
      </nav>

      <p class="eco-eyebrow">Volume <%= @book.volume_number %></p>
      <h1 class="font-display text-5xl md:text-6xl text-eco-white leading-[1.05]">
        <%= @book.localized_title(I18n.locale) %>
      </h1>
      <p class="font-display italic text-2xl text-eco-green-light">
        <%= @book.localized_tagline(I18n.locale) %>
      </p>
      <p class="eco-subhead max-w-2xl">
        <%= @book.localized_description(I18n.locale) %>
      </p>

      <div class="flex flex-wrap items-center gap-4 pt-2">
        <%= link_to read_book_path(@book.slug), class: "eco-btn-primary text-sm" do %>
          <span class="mr-2">📖</span> <%= t("books.show.open_book", default: "Open the book") %>
        <% end %>
        <%= link_to t("home.cta_request"), request_free_copy_path, class: "eco-btn-ghost text-sm" %>
        <% if @audiobook %>
          <%= link_to t("home.cta_listen"), audiobook_path(@audiobook), class: "eco-btn-ghost text-sm" %>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ─── Chapters ─────────────────────────────────────────────────────── %>
<section class="border-y border-eco-border bg-eco-surface/30">
  <div class="max-w-5xl mx-auto px-6 py-24">
    <div class="flex items-end justify-between flex-wrap gap-6 mb-12" data-controller="reveal">
      <div>
        <div class="flex items-center gap-4 mb-4">
          <span class="section-num">— Chapters</span>
        </div>
        <h2 class="font-display text-4xl md:text-5xl text-eco-white">
          <%= t("books.show.chapters_heading") %>
        </h2>
      </div>
      <p class="text-eco-text-muted text-sm max-w-sm">
        <%= t("books.show.chapters_helper") %>
      </p>
    </div>

    <ol class="divide-y divide-eco-border border-y border-eco-border">
      <% all_chapters = (@preview_chapters + @gated_chapters).sort_by(&:position) %>
      <% all_chapters.each do |chapter| %>
        <% gated = !chapter.is_preview %>
        <li class="py-6 flex items-center justify-between gap-6 group" data-controller="reveal">
          <div class="flex items-center gap-6 min-w-0">
            <span class="font-display italic text-eco-green text-xl shrink-0 w-12 text-right">
              <%= "%02d" % chapter.position %>
            </span>
            <div class="min-w-0">
              <h3 class="font-display text-2xl text-eco-white truncate">
                <%= chapter.title %>
              </h3>
              <% if gated %>
                <p class="text-xs tracking-wider uppercase text-eco-text-muted mt-1">
                  <%= t("books.show.gated") %>
                </p>
              <% else %>
                <p class="text-xs tracking-wider uppercase text-eco-green-light mt-1">
                  <%= t("books.show.preview") %>
                </p>
              <% end %>
            </div>
          </div>
          <% if gated %>
            <%= link_to request_free_copy_path,
                        class: "shrink-0 eco-btn-ghost text-xs !py-2 !px-4" do %>
              🔒 <%= t("books.show.unlock") %>
            <% end %>
          <% else %>
            <%= link_to book_chapter_path(@book.slug, chapter.slug),
                        class: "shrink-0 text-eco-green text-sm tracking-wider uppercase font-medium group-hover:gap-2 inline-flex items-center gap-1 transition-all" do %>
              <%= t("books.show.read") %> <span>→</span>
            <% end %>
          <% end %>
        </li>
      <% end %>
    </ol>
  </div>
</section>

<%# ─── Audiobook teaser ─────────────────────────────────────────────── %>
<% if @audiobook %>
  <section class="max-w-5xl mx-auto px-6 py-24">
    <div class="rounded-3xl border border-eco-border bg-eco-surface p-10 md:p-14 flex flex-col md:flex-row md:items-center md:justify-between gap-8"
         data-controller="reveal">
      <div>
        <p class="eco-eyebrow"><%= t("nav.audiobooks") %></p>
        <h3 class="font-display text-3xl md:text-4xl text-eco-white mt-2">
          <%= t("books.show.audiobook_heading") %>
        </h3>
        <p class="text-eco-text-muted mt-3 max-w-md">
          <%= t("books.show.audiobook_helper") %>
        </p>
      </div>
      <%= link_to t("home.cta_listen"), audiobook_path(@audiobook), class: "eco-btn-primary text-sm whitespace-nowrap" %>
    </div>
  </section>
<% end %>
