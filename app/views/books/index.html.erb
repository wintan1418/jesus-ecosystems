<% content_for :title, "#{t('books.index.heading')} · #{t('site.name')}" %>

<section class="relative pt-40 pb-32" style="background: var(--color-eco-cream);">
  <span class="eco-edge-label">— Books</span>

  <div class="max-w-[1240px] mx-auto px-6 md:px-14">
    <div class="text-center max-w-3xl mx-auto" data-controller="reveal">
      <p class="eco-eyebrow center"><%= t("books.index.eyebrow") %></p>
      <h1 class="font-display text-[clamp(44px,7vw,78px)] leading-[1.02] mt-5 text-eco-ink" style="font-weight: 600;">
        <%= t("books.index.heading_1") %><br>
        <em style="color: var(--color-eco-ink); font-weight: 400;"><%= t("books.index.heading_2") %></em>
      </h1>
      <p class="mt-6 eco-subhead mx-auto" style="max-width: 540px;">
        <%= t("books.index.subhead") %>
      </p>
    </div>

    <div class="mt-20 grid md:grid-cols-2 gap-12 max-w-4xl mx-auto">
      <% @books.each_with_index do |book, i| %>
        <%= link_to book_path(book.slug), class: "group block eco-volume-card-light", data: { controller: "reveal" } do %>
          <article>
            <div class="eco-book-frame">
              <img src="/source-assets/volume-<%= book.volume_number %>.jpg"
                   alt="<%= book.localized_title(I18n.locale) %>"
                   loading="lazy">
            </div>

            <div class="pt-7">
              <p class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft">Volume <%= book.volume_number %></p>
              <h2 class="font-display text-3xl md:text-4xl text-eco-ink mt-2" style="font-weight: 500;">
                <%= book.localized_title(I18n.locale) %>
              </h2>
              <p class="text-eco-ink-soft mt-4 leading-relaxed text-[15px]">
                <%= book.localized_description(I18n.locale) %>
              </p>
              <span class="mt-6 inline-flex items-center gap-2 font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink group-hover:gap-4 transition-all">
                <%= t("home.volumes.read_more") %> <span aria-hidden="true">→</span>
              </span>
            </div>
          </article>
        <% end %>
      <% end %>
    </div>
  </div>
</section>
