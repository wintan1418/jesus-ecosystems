<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <% if @newsletter.preheader.present? %>
      <%# Hidden preheader text — shown in the inbox preview alongside the subject. %>
      <div style="display:none;font-size:1px;color:#1c2015;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;">
        <%= @newsletter.preheader %>
      </div>
    <% end %>
  </head>
  <body style="margin:0;padding:0;background:#f5f0dc;font-family:Georgia,serif;color:#1c2015;line-height:1.65;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background:#f5f0dc;padding:32px 16px;">
      <tr>
        <td align="center">
          <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:18px;overflow:hidden;border:1px solid rgba(28,32,21,0.06);">

            <%# Header bar %>
            <tr>
              <td style="background:#1c2015;padding:22px 32px;">
                <table width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="font-family:Georgia,serif;color:#d1dba0;font-size:18px;letter-spacing:0.04em;">
                      <%= @site_name %>
                    </td>
                    <td align="right" style="font-family:Georgia,serif;color:rgba(245,240,220,0.55);font-size:11px;letter-spacing:0.25em;text-transform:uppercase;">
                      Weekly · <%= Date.current.strftime("%b %-d, %Y") %>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <%# Body %>
            <tr>
              <td style="padding:42px 40px 16px;">
                <h1 style="margin:0 0 24px;font-family:Georgia,serif;font-weight:700;font-size:30px;line-height:1.15;color:#1c2015;">
                  <%= @newsletter.subject %>
                </h1>

                <div style="font-size:16px;line-height:1.7;color:#1c2015;">
                  <%= @newsletter.body %>
                </div>
              </td>
            </tr>

            <%# Footer %>
            <tr>
              <td style="padding:28px 40px 36px;border-top:1px solid rgba(28,32,21,0.08);">
                <p style="margin:0 0 6px;font-size:12px;color:rgba(28,32,21,0.55);">
                  Sent to <%= @subscriber.email %><% if @subscriber.first_name.present? %> · <%= @subscriber.first_name %><% end %>
                </p>
                <p style="margin:0;font-size:11px;color:rgba(28,32,21,0.45);">
                  © <%= Date.current.year %> <%= @site_name %> ·
                  <a href="<%= @site_url %>" style="color:#3a4a1e;text-decoration:none;">visit the site</a>
                </p>
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
