<aside class="admin-sidebar">
  <div class="admin-brand">
    <%= link_to admin_root_path, class: "flex items-center group", aria: { label: t("site.name") } do %>
      <%= image_tag "/source-assets/logo.png",
                    alt: t("site.name"),
                    class: "h-10 w-auto opacity-90 group-hover:opacity-100 transition" %>
    <% end %>
    <p class="mt-3 text-[10px] tracking-[0.3em] uppercase text-eco-text-muted font-mono">
      Admin · CMS
    </p>
  </div>

  <nav class="admin-nav">
    <div class="admin-nav-group">
      <p class="admin-nav-group-label">Overview</p>
      <%= link_to admin_root_path, class: admin_nav_class(controller_name == "dashboard") do %>
        <span class="admin-nav-icon">◎</span> Dashboard
      <% end %>
      <%= link_to admin_home_content_path, class: admin_nav_class(controller_name == "home_content") do %>
        <span class="admin-nav-icon">✎</span> Home page content
      <% end %>
    </div>

    <div class="admin-nav-group">
      <p class="admin-nav-group-label">Content</p>
      <%= link_to admin_books_path, class: admin_nav_class(controller_name.in?(%w[books book_translations])) do %>
        <span class="admin-nav-icon">❖</span> Books
      <% end %>
      <%= link_to admin_chapters_path, class: admin_nav_class(controller_name == "chapters") do %>
        <span class="admin-nav-icon">¶</span> Chapters
      <% end %>
      <%= link_to admin_audiobooks_path, class: admin_nav_class(controller_name == "audiobooks") do %>
        <span class="admin-nav-icon">♪</span> Audiobooks
      <% end %>
    </div>

    <div class="admin-nav-group">
      <p class="admin-nav-group-label">Outreach</p>
      <%= link_to admin_free_copy_requests_path, class: admin_nav_class(controller_name == "free_copy_requests") do %>
        <span class="admin-nav-icon">✦</span> Free copy requests
        <% pending = FreeCopyRequest.where(status: "pending").count rescue 0 %>
        <% if pending > 0 %>
          <span class="admin-nav-badge"><%= pending %></span>
        <% end %>
      <% end %>
      <%= link_to admin_email_subscribers_path, class: admin_nav_class(controller_name == "email_subscribers") do %>
        <span class="admin-nav-icon">✉</span> Subscribers
      <% end %>
      <% if defined?(admin_newsletters_path) %>
        <%= link_to admin_newsletters_path, class: admin_nav_class(controller_name == "newsletters") do %>
          <span class="admin-nav-icon">📨</span> Weekly broadcasts
        <% end %>
      <% end %>
    </div>

    <div class="admin-nav-group">
      <p class="admin-nav-group-label">System</p>
      <%= link_to admin_site_settings_path, class: admin_nav_class(controller_name == "site_settings") do %>
        <span class="admin-nav-icon">⚙</span> Site settings
      <% end %>
      <%= link_to root_path(locale: "en"), target: "_blank", class: "admin-nav-link" do %>
        <span class="admin-nav-icon">↗</span> View site
      <% end %>
    </div>
  </nav>

  <div class="admin-footer">
    <p class="text-[10px] tracking-[0.25em] uppercase text-eco-text-muted font-mono mb-2">Signed in</p>
    <p class="text-sm text-eco-white truncate"><%= current_admin.email %></p>
    <%= button_to destroy_admin_session_path, method: :delete, class: "admin-signout" do %>
      Sign out →
    <% end %>
  </div>
</aside>
