<% content_for :title, "Languages · Admin" %>

<%= admin_page_header "Languages", eyebrow: "System",
      subtitle: "Control which languages appear in the header dropdown and footer column." %>

<div class="admin-card">
  <div class="admin-card-header">
    <h3 class="admin-card-title">Dropdown entries</h3>
    <p class="text-xs text-eco-ink-soft">
      Codes that match a real locale route switch the site to that language.
      Codes without a translation yet still show in the menu but fall back to the default locale on click.
    </p>
  </div>

  <%= form_with url: admin_languages_path, method: :patch,
                data: { controller: "language-rows" },
                class: "space-y-5" do |f| %>

    <div class="admin-table-wrap">
      <table class="admin-table">
        <thead>
          <tr>
            <th style="width: 80px;">Code</th>
            <th>Display name</th>
            <th style="width: 110px;">Status</th>
            <th style="width: 60px;"></th>
          </tr>
        </thead>
        <tbody data-language-rows-target="list">
          <% @languages.each do |entry| %>
            <%
              code   = entry["code"].to_s
              name   = entry["name"].to_s
              live   = @available_locales.include?(code)
            %>
            <tr data-language-rows-target="row">
              <td>
                <input type="text" name="languages[][code]" value="<%= code %>"
                       placeholder="fr" maxlength="5"
                       class="eco-input" style="text-transform: lowercase;">
              </td>
              <td>
                <input type="text" name="languages[][name]" value="<%= name %>"
                       placeholder="Français"
                       class="eco-input">
              </td>
              <td>
                <% if live %>
                  <span class="admin-badge admin-badge--shipped">Live</span>
                <% else %>
                  <span class="admin-badge admin-badge--pending">Pending</span>
                <% end %>
              </td>
              <td>
                <button type="button" class="admin-btn admin-btn--danger admin-btn--xs"
                        data-action="click->language-rows#remove">×</button>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <%# Template row — cloned on Add click %>
    <template data-language-rows-target="template">
      <tr data-language-rows-target="row">
        <td>
          <input type="text" name="languages[][code]" placeholder="ar" maxlength="5"
                 class="eco-input" style="text-transform: lowercase;">
        </td>
        <td>
          <input type="text" name="languages[][name]" placeholder="العربية"
                 class="eco-input">
        </td>
        <td><span class="admin-badge admin-badge--pending">Pending</span></td>
        <td>
          <button type="button" class="admin-btn admin-btn--danger admin-btn--xs"
                  data-action="click->language-rows#remove">×</button>
        </td>
      </tr>
    </template>

    <div class="flex items-center justify-between gap-4">
      <button type="button" class="admin-btn admin-btn--ghost"
              data-action="click->language-rows#add">+ Add language</button>
      <%= f.submit "Save languages", class: "admin-btn admin-btn--primary" %>
    </div>
  <% end %>
</div>

<div class="admin-card mt-6">
  <div class="admin-card-header">
    <h3 class="admin-card-title">Available locale routes</h3>
  </div>
  <p class="text-sm text-eco-ink-soft mb-3">
    These are the codes that currently have a YAML translation file in <code class="font-mono text-xs">config/locales/</code>:
  </p>
  <div class="flex flex-wrap gap-2">
    <% @available_locales.each do |loc| %>
      <span class="admin-badge admin-badge--shipped"><%= loc.upcase %></span>
    <% end %>
  </div>
  <p class="text-xs text-eco-ink-soft mt-4">
    To make a "Pending" language go Live, add the corresponding YAML file under
    <code class="font-mono">config/locales/&lt;code&gt;.yml</code> and add the code to
    <code class="font-mono">config.i18n.available_locales</code> in <code class="font-mono">config/application.rb</code>.
  </p>
</div>
