<% content_for :title, "Journal · Admin" %>

<%= admin_page_header "Journal", eyebrow: "Content",
      subtitle: "Every post on the journal." do %>
  <%= link_to "New post", new_admin_post_path, class: "admin-btn admin-btn--primary" %>
<% end %>

<div class="admin-filter-bar">
  <%= link_to "All", admin_posts_path,
              class: "admin-filter-pill #{'admin-filter-pill--active' if params[:locale].blank?}" %>
  <% %w[en es pt].each do |loc| %>
    <%= link_to loc.upcase, admin_posts_path(locale: loc),
                class: "admin-filter-pill #{'admin-filter-pill--active' if params[:locale] == loc}" %>
  <% end %>
  <%= form_with url: admin_posts_path, method: :get, class: "flex-1 flex justify-end" do |f| %>
    <%= f.text_field :q, value: params[:q], placeholder: "Search title, excerpt, tags…", class: "admin-search" %>
    <% if params[:locale].present? %>
      <%= f.hidden_field :locale, value: params[:locale] %>
    <% end %>
  <% end %>
</div>

<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th style="width:80px">Cover</th>
        <th>Title</th>
        <th>Locale</th>
        <th>Published</th>
        <th>Tags</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% if @posts.any? %>
        <% @posts.each do |post| %>
          <tr>
            <td>
              <% if post.featured_image.attached? %>
                <%= image_tag post.featured_image, class: "admin-table-cover" %>
              <% else %>
                <div class="admin-table-cover bg-eco-bg flex items-center justify-center text-eco-text-muted text-xs">—</div>
              <% end %>
            </td>
            <td>
              <%= link_to post.title, admin_post_path(post), class: "font-display text-base" %>
              <% if post.excerpt.present? %>
                <div class="text-xs text-eco-text-muted mt-1 max-w-md truncate"><%= post.excerpt %></div>
              <% end %>
            </td>
            <td><span class="admin-badge admin-badge--shipped"><%= post.locale.upcase %></span></td>
            <td class="text-xs text-eco-text-muted">
              <% if post.published? %>
                <%= post.published_at.strftime("%b %-d, %Y") %>
              <% else %>
                <span class="admin-badge admin-badge--pending">Draft</span>
              <% end %>
            </td>
            <td class="text-xs text-eco-text-muted"><%= post.tag_list.first(3).map { |t| "##{t}" }.join(" ") %></td>
            <td>
              <%= link_to "Edit", edit_admin_post_path(post), class: "admin-btn admin-btn--ghost admin-btn--xs" %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr><td colspan="6" class="admin-table-empty">— Nothing published yet. Start writing.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
