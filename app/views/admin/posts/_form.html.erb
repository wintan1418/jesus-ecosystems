<%= form_with model: [:admin, post], class: "admin-form", multipart: true do |f| %>
  <% if post.errors.any? %>
    <div class="admin-flash admin-flash--alert">
      <strong><%= pluralize(post.errors.count, "error") %>:</strong>
      <%= post.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :title, class: "admin-field-label" %>
      <%= f.text_field :title, class: "admin-field-input", required: true %>
    </div>
    <div class="admin-field">
      <%= f.label :locale, class: "admin-field-label" %>
      <%= f.select :locale, [["English", "en"], ["Español", "es"], ["Português", "pt"]],
                   {}, class: "admin-field-select" %>
    </div>
  </div>

  <div class="admin-field">
    <%= f.label :excerpt, "Excerpt (2–3 sentences)", class: "admin-field-label" %>
    <%= f.text_area :excerpt, class: "admin-field-textarea", rows: 3 %>
  </div>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :published_at, "Published at", class: "admin-field-label" %>
      <%= f.datetime_local_field :published_at, class: "admin-field-input" %>
      <p class="admin-field-help">Leave in the past to publish immediately. Set in the future to schedule.</p>
    </div>
    <div class="admin-field">
      <%= f.label :reading_minutes, "Reading time (minutes)", class: "admin-field-label" %>
      <%= f.number_field :reading_minutes, class: "admin-field-input", min: 1 %>
    </div>
  </div>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :author_name, class: "admin-field-label" %>
      <%= f.text_field :author_name, class: "admin-field-input" %>
    </div>
    <div class="admin-field">
      <%= f.label :tag_list, "Tags (comma-separated)", class: "admin-field-label" %>
      <%= f.text_field :tag_list, value: post.tag_list.join(", "), class: "admin-field-input",
                       placeholder: "manifesto, ecosystem, field notes" %>
    </div>
  </div>

  <div class="admin-field">
    <%= f.label :featured_image, "Featured image", class: "admin-field-label" %>
    <% if post.featured_image.attached? %>
      <%= image_tag post.featured_image, class: "mb-3 rounded-lg border border-eco-border", style: "max-height:180px" %>
    <% end %>
    <%= f.file_field :featured_image, class: "admin-field-file", accept: "image/*" %>
    <p class="admin-field-help">Optional. Landscape orientation reads best in the journal grid.</p>
  </div>

  <div class="admin-field">
    <label class="admin-field-label">Body</label>
    <%= f.rich_text_area :body %>
  </div>

  <div class="admin-form-actions">
    <%= f.submit post.persisted? ? "Save changes" : "Create post", class: "admin-btn admin-btn--primary" %>
    <%= link_to "Cancel",
                post.persisted? ? admin_post_path(post) : admin_posts_path,
                class: "admin-btn admin-btn--ghost" %>
  </div>
<% end %>
