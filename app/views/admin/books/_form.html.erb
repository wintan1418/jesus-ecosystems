<%= form_with model: [:admin, book], class: "admin-form", multipart: true do |f| %>
  <% if book.errors.any? %>
    <div class="admin-flash admin-flash--alert">
      <strong><%= pluralize(book.errors.count, "error") %>:</strong>
      <%= book.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :title, class: "admin-field-label" %>
      <%= f.text_field :title, class: "admin-field-input", required: true %>
    </div>

    <div class="admin-field">
      <%= f.label :volume_number, "Volume number", class: "admin-field-label" %>
      <%= f.number_field :volume_number, class: "admin-field-input", required: true, min: 1, max: 10 %>
    </div>
  </div>

  <div class="admin-field">
    <%= f.label :tagline, class: "admin-field-label" %>
    <%= f.text_field :tagline, class: "admin-field-input" %>
  </div>

  <div class="admin-field">
    <%= f.label :description, class: "admin-field-label" %>
    <%= f.text_area :description, class: "admin-field-textarea", rows: 4 %>
  </div>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :published_at, "Published at", class: "admin-field-label" %>
      <%= f.datetime_local_field :published_at, class: "admin-field-input" %>
    </div>

    <div class="admin-field">
      <%= f.label :position, class: "admin-field-label" %>
      <%= f.number_field :position, class: "admin-field-input" %>
    </div>
  </div>

  <div class="admin-field">
    <%= f.label :cover_image, "Cover image", class: "admin-field-label" %>
    <% if book.cover_image.attached? %>
      <%= image_tag book.cover_image, class: "admin-table-cover mb-3", style: "width:120px;height:150px" %>
    <% end %>
    <%= f.file_field :cover_image, class: "admin-field-file", accept: "image/*" %>
    <p class="admin-field-help">JPG, PNG, or WebP — will be processed into multiple sizes.</p>
  </div>

  <div class="admin-form-actions">
    <%= f.submit book.persisted? ? "Save changes" : "Create book", class: "admin-btn admin-btn--primary" %>
    <%= link_to "Cancel", book.persisted? ? admin_book_path(book) : admin_books_path,
                class: "admin-btn admin-btn--ghost" %>
  </div>
<% end %>
