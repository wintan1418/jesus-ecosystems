<%= form_with model: [:admin, setting], class: "admin-form" do |f| %>
  <% if setting.errors.any? %>
    <div class="admin-flash admin-flash--alert">
      <strong><%= pluralize(setting.errors.count, "error") %>:</strong>
      <%= setting.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="admin-field">
    <%= f.label :key, class: "admin-field-label" %>
    <%= f.text_field :key, class: "admin-field-input", required: true %>
    <p class="admin-field-help">Stable identifier referenced from views. Example: <code>shoutout_video_url</code></p>
  </div>

  <div class="admin-field">
    <%= f.label :value, class: "admin-field-label" %>
    <%= f.text_area :value, class: "admin-field-textarea", rows: 10 %>
    <p class="admin-field-help">Plain text or JSON. Edited inline without redeploy.</p>
  </div>

  <div class="admin-form-actions">
    <%= f.submit setting.persisted? ? "Save changes" : "Create setting", class: "admin-btn admin-btn--primary" %>
    <%= link_to "Cancel", admin_site_settings_path, class: "admin-btn admin-btn--ghost" %>
  </div>
<% end %>
