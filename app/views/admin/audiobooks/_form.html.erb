<%= form_with model: audiobook, url: form_url, method: form_method, class: "admin-form", multipart: true do |f| %>
  <% if audiobook.errors.any? %>
    <div class="admin-flash admin-flash--alert">
      <strong><%= pluralize(audiobook.errors.count, "error") %>:</strong>
      <%= audiobook.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="admin-field">
    <%= f.label :title, class: "admin-field-label" %>
    <%= f.text_field :title, class: "admin-field-input", required: true %>
  </div>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :locale, class: "admin-field-label" %>
      <%= f.select :locale, [["English", "en"], ["Español", "es"], ["Português", "pt"]],
                   {}, class: "admin-field-select" %>
    </div>
    <div class="admin-field">
      <%= f.label :duration_seconds, "Duration (seconds)", class: "admin-field-label" %>
      <%= f.number_field :duration_seconds, class: "admin-field-input" %>
    </div>
  </div>

  <div class="admin-field">
    <%= f.label :position, class: "admin-field-label" %>
    <%= f.number_field :position, class: "admin-field-input" %>
  </div>

  <div class="admin-field">
    <%= f.label :audio_file, "Audio file", class: "admin-field-label" %>
    <% if audiobook.audio_file.attached? %>
      <p class="text-xs text-eco-green-light mb-2">Currently: <%= audiobook.audio_file.filename %></p>
    <% end %>
    <%= f.file_field :audio_file, class: "admin-field-file", accept: "audio/*" %>
    <p class="admin-field-help">MP3 / M4A / WAV — stored in Active Storage (R2 in production).</p>
  </div>

  <div class="admin-form-actions">
    <%= f.submit audiobook.persisted? ? "Save changes" : "Create audiobook", class: "admin-btn admin-btn--primary" %>
    <%= link_to "Cancel",
                (audiobook.persisted? ? admin_audiobook_path(audiobook) : admin_book_path(audiobook.book || params[:book_id])),
                class: "admin-btn admin-btn--ghost" %>
  </div>
<% end %>
