<%= form_with model: [:admin, @book, translation], class: "admin-form" do |f| %>
  <% if translation.errors.any? %>
    <div class="admin-flash admin-flash--alert">
      <strong><%= pluralize(translation.errors.count, "error") %>:</strong>
      <%= translation.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="admin-field">
    <%= f.label :locale, class: "admin-field-label" %>
    <%= f.select :locale, [["English", "en"], ["Español", "es"], ["Português", "pt"]],
                 {}, class: "admin-field-select", required: true %>
  </div>

  <div class="admin-field">
    <%= f.label :title, class: "admin-field-label" %>
    <%= f.text_field :title, class: "admin-field-input", required: true %>
  </div>

  <div class="admin-field">
    <%= f.label :tagline, class: "admin-field-label" %>
    <%= f.text_field :tagline, class: "admin-field-input" %>
  </div>

  <div class="admin-field">
    <%= f.label :description, class: "admin-field-label" %>
    <%= f.text_area :description, class: "admin-field-textarea", rows: 4 %>
  </div>

  <div class="admin-field">
    <%= f.label :slug, class: "admin-field-label" %>
    <%= f.text_field :slug, class: "admin-field-input" %>
  </div>

  <div class="admin-form-actions">
    <%= f.submit translation.persisted? ? "Save" : "Add translation", class: "admin-btn admin-btn--primary" %>
    <%= link_to "Cancel", admin_book_path(@book), class: "admin-btn admin-btn--ghost" %>
  </div>
<% end %>
