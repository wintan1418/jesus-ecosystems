<%= form_with model: [:admin, episode], class: "admin-form", multipart: true do |f| %>
  <% if episode.errors.any? %>
    <div class="admin-flash admin-flash--alert">
      <strong><%= pluralize(episode.errors.count, "error") %>:</strong>
      <%= episode.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :title, class: "admin-field-label" %>
      <%= f.text_field :title, class: "admin-field-input", required: true %>
    </div>
    <div class="admin-field">
      <%= f.label :locale, class: "admin-field-label" %>
      <%= f.select :locale, [["English", "en"], ["Español", "es"], ["Português", "pt"]],
                   {}, class: "admin-field-select" %>
    </div>
  </div>

  <div class="admin-field">
    <%= f.label :description, "Short description (1–2 sentences)", class: "admin-field-label" %>
    <%= f.text_area :description, class: "admin-field-textarea", rows: 3 %>
  </div>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :season, class: "admin-field-label" %>
      <%= f.number_field :season, class: "admin-field-input", min: 1 %>
    </div>
    <div class="admin-field">
      <%= f.label :number, "Episode number", class: "admin-field-label" %>
      <%= f.number_field :number, class: "admin-field-input", min: 1 %>
    </div>
  </div>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :published_at, "Published at", class: "admin-field-label" %>
      <%= f.datetime_local_field :published_at, class: "admin-field-input" %>
    </div>
    <div class="admin-field">
      <%= f.label :duration_seconds, "Duration (seconds)", class: "admin-field-label" %>
      <%= f.number_field :duration_seconds, class: "admin-field-input", min: 0 %>
    </div>
  </div>

  <div class="admin-field">
    <label class="admin-checkbox">
      <%= f.check_box :explicit %>
      <span>Explicit content</span>
    </label>
  </div>

  <div class="admin-field">
    <%= f.label :audio_file, "Audio file (mp3 / m4a)", class: "admin-field-label" %>
    <% if episode.audio_file.attached? %>
      <p class="text-xs text-eco-green-light mb-2">Currently: <%= episode.audio_file.filename %> · <%= number_to_human_size(episode.audio_file.byte_size) %></p>
    <% end %>
    <%= f.file_field :audio_file, class: "admin-field-file", accept: "audio/*" %>
  </div>

  <div class="admin-field">
    <%= f.label :cover_image, "Cover image (square)", class: "admin-field-label" %>
    <% if episode.cover_image.attached? %>
      <%= image_tag episode.cover_image, class: "mb-3 rounded-lg border border-eco-border", style: "max-height: 160px" %>
    <% end %>
    <%= f.file_field :cover_image, class: "admin-field-file", accept: "image/*" %>
    <p class="admin-field-help">If left blank, the channel's main cover is used.</p>
  </div>

  <div class="admin-field">
    <label class="admin-field-label">Show notes</label>
    <%= f.rich_text_area :body %>
  </div>

  <div class="admin-form-actions">
    <%= f.submit episode.persisted? ? "Save changes" : "Create episode", class: "admin-btn admin-btn--primary" %>
    <%= link_to "Cancel",
                episode.persisted? ? admin_episode_path(episode) : admin_episodes_path,
                class: "admin-btn admin-btn--ghost" %>
  </div>
<% end %>
