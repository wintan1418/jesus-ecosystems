<%= form_with model: [:admin, newsletter], class: "admin-form" do |f| %>
  <% if newsletter.errors.any? %>
    <div class="admin-flash admin-flash--alert">
      <strong><%= pluralize(newsletter.errors.count, "error") %>:</strong>
      <%= newsletter.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :subject, class: "admin-field-label" %>
      <%= f.text_field :subject, class: "admin-field-input", required: true,
                       placeholder: "This week — what we're seeing in the ecosystem" %>
    </div>
    <div class="admin-field">
      <%= f.label :locale, "Send to subscribers in", class: "admin-field-label" %>
      <%= f.select :locale,
                   [["English (EN)", "en"], ["Español (ES)", "es"], ["Português (PT)", "pt"]],
                   {}, class: "admin-field-select" %>
    </div>
  </div>

  <div class="admin-field">
    <%= f.label :preheader, "Preheader (inbox preview text)", class: "admin-field-label" %>
    <%= f.text_field :preheader, class: "admin-field-input",
                     placeholder: "A short preview shown next to the subject in the inbox." %>
    <p class="admin-field-help">Optional — keeps inbox previews intentional instead of leaking your first sentence.</p>
  </div>

  <div class="admin-field">
    <label class="admin-field-label">Body</label>
    <%= f.rich_text_area :body %>
    <p class="admin-field-help">Write what you'd say in a quiet letter — short, generous, useful.</p>
  </div>

  <div class="admin-form-actions">
    <%= f.submit newsletter.persisted? ? "Save changes" : "Save draft", class: "admin-btn admin-btn--primary" %>
    <%= link_to "Cancel",
                newsletter.persisted? ? admin_newsletter_path(newsletter) : admin_newsletters_path,
                class: "admin-btn admin-btn--ghost" %>
  </div>
<% end %>
