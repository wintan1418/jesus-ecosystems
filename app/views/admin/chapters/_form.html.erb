<%= form_with model: form_url, scope: :chapter, url: form_url, class: "admin-form" do |f| %>
  <% if chapter.errors.any? %>
    <div class="admin-flash admin-flash--alert">
      <strong><%= pluralize(chapter.errors.count, "error") %>:</strong>
      <%= chapter.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :title, class: "admin-field-label" %>
      <%= f.text_field :title, value: chapter.title, class: "admin-field-input", required: true %>
    </div>
    <div class="admin-field">
      <%= f.label :locale, class: "admin-field-label" %>
      <%= f.select :locale,
                   [["English", "en"], ["Español", "es"], ["Português", "pt"]],
                   { selected: chapter.locale },
                   class: "admin-field-select", required: true %>
    </div>
  </div>

  <div class="admin-form-grid-2">
    <div class="admin-field">
      <%= f.label :position, class: "admin-field-label" %>
      <%= f.number_field :position, value: chapter.position, class: "admin-field-input" %>
    </div>
    <div class="admin-field justify-center">
      <label class="admin-checkbox mt-6">
        <%= f.check_box :is_preview, checked: chapter.is_preview? %>
        <span>Open to public (preview chapter)</span>
      </label>
    </div>
  </div>

  <div class="admin-field">
    <label class="admin-field-label">Body</label>
    <%= f.rich_text_area :body, value: chapter.body&.to_s %>
  </div>

  <div class="admin-form-actions">
    <%= f.submit chapter.persisted? ? "Save changes" : "Create chapter", class: "admin-btn admin-btn--primary" %>
    <%= link_to "Cancel",
                (chapter.persisted? ? admin_chapter_path(chapter) : admin_book_path(chapter.book || params[:book_id])),
                class: "admin-btn admin-btn--ghost" %>
  </div>
<% end %>
