<% content_for :title, "#{@post.title} · #{t('site.name')}" %>

<article class="relative pt-40 pb-32 overflow-hidden bg-mesh">
  <div class="absolute -top-32 -left-32 size-[36rem] rounded-full bg-eco-green/10 blur-[140px] pointer-events-none"></div>

  <div class="relative max-w-3xl mx-auto px-6">
    <nav class="flex items-center gap-2 text-xs tracking-wider uppercase text-eco-text-muted mb-10">
      <%= link_to t("nav.home"),    root_path,    class: "hover:text-eco-green-light" %>
      <span>/</span>
      <%= link_to "Journal",        journal_path, class: "hover:text-eco-green-light" %>
      <span>/</span>
      <span class="text-eco-green-light truncate"><%= @post.title %></span>
    </nav>

    <header class="mb-12 space-y-6" data-controller="reveal">
      <p class="font-mono text-[10px] tracking-[0.3em] uppercase text-eco-green-light">
        <%= @post.published_at.strftime("%B %d, %Y") %> · <%= @post.reading_time %>
      </p>

      <h1 class="font-display text-4xl md:text-6xl text-eco-white leading-[1.05]">
        <%= @post.title %>
      </h1>

      <% if @post.excerpt.present? %>
        <p class="eco-subhead max-w-2xl">
          <%= @post.excerpt %>
        </p>
      <% end %>

      <span class="block draw-line" style="width: 72px"></span>
    </header>

    <% if @post.featured_image.attached? %>
      <figure class="mb-12 -mx-6 md:mx-0">
        <%= image_tag @post.featured_image,
                      alt: @post.title,
                      class: "w-full rounded-3xl border border-eco-border" %>
      </figure>
    <% end %>

    <div class="prose-eco" data-controller="reveal">
      <%= @post.body %>
    </div>

    <% if @post.tag_list.any? %>
      <div class="mt-16 pt-8 border-t border-eco-border flex flex-wrap gap-2">
        <% @post.tag_list.each do |tag| %>
          <span class="inline-flex items-center px-3 py-1.5 rounded-full border border-eco-border text-[10px] tracking-wider uppercase text-eco-text-muted font-mono">
            #<%= tag %>
          </span>
        <% end %>
      </div>
    <% end %>

    <footer class="mt-16 pt-10 border-t border-eco-border flex items-center justify-between">
      <%= link_to journal_path, class: "text-eco-text-muted hover:text-eco-green-light text-sm tracking-wider uppercase inline-flex items-center gap-2" do %>
        <span>←</span> More journal entries
      <% end %>
      <%= link_to "Request free copies", request_free_copy_path, class: "eco-btn-primary text-sm" %>
    </footer>
  </div>
</article>
