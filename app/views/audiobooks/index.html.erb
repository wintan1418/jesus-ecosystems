<% content_for :title, "#{t('audiobooks.index.heading_1')} #{t('audiobooks.index.heading_2')} · #{t('site.name')}" %>

<%
  # Demo MP3s while real audiobook files are still being mastered.
  demo_audio_for = ->(audiobook) {
    n = ((audiobook.id.to_i - 1) % 6) + 1
    "https://www.soundhelix.com/examples/mp3/SoundHelix-Song-#{n}.mp3"
  }
%>

<section class="relative pt-40 pb-32" style="background: var(--color-eco-cream);">
  <span class="eco-edge-label">— Audiobooks</span>

  <div class="relative max-w-[1240px] mx-auto px-6 md:px-14">
    <div class="text-center max-w-3xl mx-auto mb-16" data-controller="reveal">
      <p class="eco-eyebrow center"><%= t("audiobooks.index.eyebrow") %></p>
      <h1 class="font-display text-[clamp(44px,7vw,78px)] leading-[1.02] mt-5 text-eco-ink" style="font-weight: 600;">
        <%= t("audiobooks.index.heading_1") %><br>
        <em style="font-weight: 400;"><%= t("audiobooks.index.heading_2") %></em>
      </h1>
      <p class="mt-6 eco-subhead mx-auto" style="max-width: 540px;">
        <%= t("audiobooks.index.subhead") %>
      </p>
    </div>

    <div class="grid lg:grid-cols-12 gap-10" data-controller="audio-player">
      <%# Player panel %>
      <div class="lg:col-span-7">
        <div class="rounded-[10px] p-10 md:p-14 relative overflow-hidden"
             style="background: var(--color-eco-cream-warm); border: 1px solid var(--color-eco-rule); box-shadow: 0 30px 60px -30px rgba(42,47,32,.18);">

          <div class="relative">
            <p class="eco-eyebrow flex items-center gap-3">
              <span><%= t("audiobooks.show.now_playing") %></span>
              <span class="font-mono text-[10px] tracking-[0.22em] text-eco-ink-soft normal-case ml-auto"
                    data-audio-player-target="status"><%= t("shared.audio_idle") %></span>
            </p>
            <h2 class="font-display text-3xl md:text-4xl text-eco-ink mt-4" style="font-weight: 500;" data-audio-player-target="title">
              <%= @current&.title || "—" %>
            </h2>

            <%# Big play button %>
            <div class="mt-12 flex items-center gap-6">
              <button type="button"
                      class="size-20 rounded-full flex items-center justify-center text-2xl hover:scale-105 transition"
                      style="background: var(--color-eco-cta-tan); color: var(--color-eco-cream); box-shadow: 0 18px 40px -10px rgba(200, 70, 52, 0.5);"
                      data-action="click->audio-player#toggle"
                      data-audio-player-target="playBtn"
                      aria-label="<%= t('shared.audio_play_pause') %>">
                <span data-audio-player-target="playIcon">▶</span>
              </button>
              <div class="flex-1 min-w-0">
                <div class="h-1.5 rounded-full overflow-hidden cursor-pointer relative"
                     style="background: rgba(42, 47, 32, 0.12);"
                     data-audio-player-target="progress"
                     data-action="click->audio-player#seek">
                  <div class="h-full" style="background: var(--color-eco-olive-deep);"
                       data-audio-player-target="fill"
                       style="width: 0"></div>
                </div>
                <div class="flex items-center justify-between mt-3 font-mono text-xs text-eco-ink-soft">
                  <span data-audio-player-target="elapsed">0:00</span>
                  <span data-audio-player-target="remaining">-0:00</span>
                </div>
              </div>
            </div>

            <audio data-audio-player-target="audio" preload="metadata"></audio>
          </div>
        </div>
      </div>

      <%# Track list %>
      <div class="lg:col-span-5">
        <p class="eco-eyebrow mb-4"><%= t("audiobooks.show.tracks") %></p>
        <ul class="space-y-3">
          <% @audiobooks.each do |ab| %>
            <li>
              <button type="button"
                      class="w-full text-left rounded-[10px] px-5 py-4 flex items-center justify-between gap-4 group transition"
                      style="background: var(--color-eco-paper); border: 1px solid var(--color-eco-rule);"
                      data-audio-track
                      data-audio-id="<%= ab.id %>"
                      data-audio-url="<%= demo_audio_for.call(ab) %>"
                      data-audio-title="<%= ab.title %>"
                      data-action="click->audio-player#load">
                <div class="flex items-center gap-4 min-w-0">
                  <span class="font-display italic text-eco-olive-deep text-lg shrink-0 w-8 text-center">
                    <%= ab.book.volume_number == 1 ? "I" : "II" %>
                  </span>
                  <div class="min-w-0">
                    <p class="font-display text-eco-ink text-lg truncate" style="font-weight: 500;"><%= ab.book.localized_title(I18n.locale) %></p>
                    <p class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mt-1">
                      <%= ab.locale.upcase %> · <%= ab.duration %>
                    </p>
                  </div>
                </div>
                <span class="size-9 rounded-full flex items-center justify-center text-sm transition"
                      style="border: 1px solid var(--color-eco-rule); color: var(--color-eco-ink); background: var(--color-eco-cream);">▶</span>
              </button>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </div>
</section>
