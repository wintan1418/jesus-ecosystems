<header class="fixed top-0 inset-x-0 z-50 eco-nav-glass">
  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
    <%= link_to root_path, class: "group flex items-center gap-3", aria: { label: t("site.name") } do %>
      <%= image_tag "/source-assets/logo.png",
                    alt: t("site.name"),
                    class: "h-9 md:h-10 w-auto opacity-90 group-hover:opacity-100 transition" %>
    <% end %>

    <nav class="hidden md:flex items-center gap-8 text-sm">
      <%= link_to t("nav.books"),       books_path,             class: "text-eco-text/80 hover:text-eco-green-light transition" %>
      <%= link_to t("nav.audiobooks"),  audiobooks_path,        class: "text-eco-text/80 hover:text-eco-green-light transition" %>
      <%= link_to "Podcast",            podcast_path,           class: "text-eco-text/80 hover:text-eco-green-light transition" %>
      <%= link_to "Journal",            journal_path,           class: "text-eco-text/80 hover:text-eco-green-light transition" %>
      <%= link_to "About",              about_path,             class: "text-eco-text/80 hover:text-eco-green-light transition" %>
      <%= link_to t("nav.request"),     request_free_copy_path, class: "text-eco-text/80 hover:text-eco-green-light transition" %>
    </nav>

    <div class="flex items-center gap-3">
      <%= render "shared/language_switcher" %>
      <%= link_to t("nav.request"), request_free_copy_path,
                  class: "hidden lg:inline-flex eco-btn-primary !py-2.5 !px-5 text-xs tracking-wider uppercase" %>
    </div>
  </div>
</header>
