<header class="fixed top-0 inset-x-0 z-50 eco-nav-glass">
  <div class="max-w-[1240px] mx-auto px-6 md:px-14 py-4 md:py-[18px] flex items-center justify-between gap-8">

    <%# ── Brand: original logo PNG ── %>
    <%= link_to root_path, class: "group flex items-center", aria: { label: t("site.name") } do %>
      <%= image_tag "/source-assets/logo.png",
                    alt: t("site.name"),
                    class: "h-9 md:h-10 w-auto opacity-90 group-hover:opacity-100 transition" %>
    <% end %>

    <%# ── Center nav ── %>
    <nav class="hidden md:flex items-center gap-9 text-[13px]" style="color: var(--color-eco-ink-soft); font-weight: 500;">
      <%= link_to t("nav.books"),       books_path,             class: "nav-link relative pb-1 hover:text-eco-ink transition" %>
      <%= link_to t("nav.audiobooks"),  audiobooks_path,        class: "nav-link relative pb-1 hover:text-eco-ink transition" %>
      <%= link_to t("nav.about"),       about_path,             class: "nav-link relative pb-1 hover:text-eco-ink transition" %>
      <%= link_to t("nav.request"),     request_free_copy_path, class: "nav-link relative pb-1 hover:text-eco-ink transition" %>
    </nav>

    <%# ── Right cluster: language + tan CTA ── %>
    <div class="flex items-center gap-4">
      <%= render "shared/language_switcher" %>
      <%= link_to t("nav.request"), request_free_copy_path,
                  class: "hidden lg:inline-flex eco-btn-primary" %>

      <%# Mobile hamburger %>
      <button class="mobile-menu-btn md:hidden" aria-expanded="false" aria-label="Open menu"
              onclick="const panel = document.getElementById('mobile-nav'); const open = panel.dataset.open === 'true'; panel.dataset.open = !open; this.setAttribute('aria-expanded', !open); document.body.style.overflow = open ? '' : 'hidden';">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <%# Mobile fullscreen nav %>
  <div id="mobile-nav" class="mobile-nav-panel" data-open="false">
    <%= link_to t("nav.books"),       books_path,             onclick: "document.getElementById('mobile-nav').dataset.open='false'; document.querySelector('.mobile-menu-btn').setAttribute('aria-expanded','false'); document.body.style.overflow='';" %>
    <%= link_to t("nav.audiobooks"),  audiobooks_path,        onclick: "document.getElementById('mobile-nav').dataset.open='false'; document.querySelector('.mobile-menu-btn').setAttribute('aria-expanded','false'); document.body.style.overflow='';" %>
    <%= link_to t("nav.about"),       about_path,             onclick: "document.getElementById('mobile-nav').dataset.open='false'; document.querySelector('.mobile-menu-btn').setAttribute('aria-expanded','false'); document.body.style.overflow='';" %>
    <%= link_to t("nav.request"),     request_free_copy_path, class: "eco-btn-primary mt-4 text-base", onclick: "document.getElementById('mobile-nav').dataset.open='false'; document.querySelector('.mobile-menu-btn').setAttribute('aria-expanded','false'); document.body.style.overflow='';" %>
  </div>
</header>

<style>
  /* Active page: 1px ink underline on the matching nav link */
  body[data-page="books"]      .nav-link[href*="/books"]:not([href*="/books/"]),
  body[data-page="audiobooks"] .nav-link[href*="/audiobooks"],
  body[data-page="about"]      .nav-link[href*="/about"],
  body[data-page="request"]    .nav-link[href*="/request-free-copy"] {
    color: var(--color-eco-ink);
  }
  body[data-page="books"]      .nav-link[href*="/books"]:not([href*="/books/"])::after,
  body[data-page="audiobooks"] .nav-link[href*="/audiobooks"]::after,
  body[data-page="about"]      .nav-link[href*="/about"]::after,
  body[data-page="request"]    .nav-link[href*="/request-free-copy"]::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--color-eco-ink);
  }
</style>

<script>
  (function(){
    const hdr = document.querySelector('.eco-nav-glass');
    if (!hdr) return;
    const mark = 50;
    let ticking = false;
    window.addEventListener('scroll', function(){
      if (!ticking) {
        requestAnimationFrame(function(){
          hdr.classList.toggle('is-scrolled', window.scrollY > mark);
          ticking = false;
        });
        ticking = true;
      }
    }, {passive: true});
  })();
</script>
