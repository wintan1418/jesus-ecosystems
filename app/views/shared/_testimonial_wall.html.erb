<%
  # Real reader letters. The wall is built to scale: drop in dozens or hundreds
  # via SiteSetting['testimonial_letters'] and the marquee duration per row
  # auto-scales below so the perceived scroll speed stays the same.
  letters = begin
    parsed = JSON.parse(SiteSetting["testimonial_letters"].to_s)
    parsed.is_a?(Array) ? parsed : []
  rescue JSON::ParserError
    []
  end
%>

<% if letters.any? %>
  <%
    letters    = letters.shuffle
    # Always 3 rows (looks balanced regardless of letter count).
    row_count  = 3
    slice_size = [(letters.size / row_count.to_f).ceil, 1].max
    rows       = letters.each_slice(slice_size).to_a

    # Marquee speed: ~28 px/sec — readable but never sluggish. Card is 320px
    # wide + 20px gap. Scroll distance = (cards_per_row * 340). 2x duplication
    # means the animation traverses cards_per_row * 340 over the full cycle.
    px_per_sec = 28.0
    card_pitch = 340 # 320px card + 20px gap
  %>

<section id="letters" data-rail-label="Letters"
         class="relative py-32 overflow-hidden"
         style="background: var(--color-eco-paper);">
  <span class="eco-edge-label">09 — Letters</span>

  <div class="relative max-w-[1240px] mx-auto px-6 md:px-14 text-center mb-14" data-controller="reveal">
    <p class="eco-eyebrow center">What Readers Are Saying</p>
    <h2 class="font-display text-[clamp(36px,5vw,60px)] leading-[1.1] mt-5">
      <span class="italic" style="color: var(--color-eco-accent);">They read.</span><br>
      <em class="text-eco-ink">Then they wrote back.</em>
    </h2>
  </div>

  <div class="letter-wall space-y-5">
    <% rows.each_with_index do |row, i| %>
      <% next if row.empty? %>
      <%
        # Duration scales with row width so 9 letters and 90 letters scroll at
        # the same readable speed. Floor at 50s so very small walls don't fly.
        duration_seconds = [(row.size * card_pitch / px_per_sec).round, 50].max
      %>
      <div class="letter-wall-row" data-direction="<%= i.even? ? 'left' : 'right' %>">
        <div class="letter-wall-track" style="animation-duration: <%= duration_seconds %>s;">
          <%# Duplicate the row twice so the CSS marquee loops seamlessly. %>
          <% 2.times do %>
            <% row.each do |l| %>
              <figure class="letter-card">
                <blockquote><%= l["quote"] || l[:quote] %></blockquote>
                <figcaption><%= l["attribution"] || l[:attribution] %></figcaption>
              </figure>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <p class="relative text-center mt-12 font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft">
    <%= letters.size %> letters · rotating · hover to pause
  </p>
</section>
<% end %>
