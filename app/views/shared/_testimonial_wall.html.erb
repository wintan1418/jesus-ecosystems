<%
  # Real reader letters, shuffled so repeat visitors see a fresh feel.
  letters = begin
    parsed = JSON.parse(SiteSetting["testimonial_letters"].to_s)
    parsed.is_a?(Array) ? parsed : []
  rescue JSON::ParserError
    []
  end
%>

<% if letters.any? %>
  <%
    letters    = letters.shuffle
    # Split across 3 rows so the marquee feels dense but readable.
    # Clamp slice size to >= 1 so we never pass 0 to each_slice — that
    # raises ArgumentError and was blowing up production when the
    # testimonial_letters SiteSetting hadn't been seeded.
    slice_size = [(letters.size / 3.0).ceil, 1].max
    rows       = letters.each_slice(slice_size).to_a
  %>
<section id="letters" data-rail-label="Letters"
         class="relative py-32 overflow-hidden border-t border-eco-border bg-eco-bg">

  <div class="absolute -top-20 left-1/3 size-[28rem] rounded-full bg-eco-green/[0.08] blur-[140px] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 text-center mb-14" data-controller="reveal">
    <div class="flex items-center justify-center gap-4 mb-5">
      <span class="section-num">— Letters</span>
      <p class="eco-eyebrow">What readers are saying</p>
    </div>
    <h2 class="font-display text-4xl md:text-6xl text-eco-white leading-[1.08]">
      They read.<br>
      <span class="italic font-normal text-eco-green-light">Then they wrote back.</span>
    </h2>
  </div>

  <div class="letter-wall space-y-5">
    <% rows.each_with_index do |row, i| %>
      <% next if row.empty? %>
      <div class="letter-wall-row" data-direction="<%= i.even? ? 'left' : 'right' %>">
        <div class="letter-wall-track">
          <%# Duplicate the row twice so the CSS marquee loops seamlessly. %>
          <% 2.times do %>
            <% row.each do |l| %>
              <figure class="letter-card">
                <blockquote><%= l["quote"] || l[:quote] %></blockquote>
                <figcaption><%= l["attribution"] || l[:attribution] %></figcaption>
              </figure>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <p class="relative text-center mt-12 text-xs tracking-[0.3em] uppercase text-eco-text-muted">
    <%= letters.size %> letters · rotating · hover to pause
  </p>
</section>
<% end %>
