<%# ── Sprout outro section (Andrew 2026-05-18: restore the original animated sprout) %>
<section class="eco-sprout-outro" data-controller="plant-grow">
  <div class="relative z-10 sprout-original">
    <%# Hand-drawn SVG — soil dashes, S-curve stem draws upward, leaves unfurl,
        seed dot pops with a soft halo. All animation lives in app.css and fires
        when plant-grow sets data-plant-grown="true" on the wrapper. %>
    <svg class="sprout-svg" viewBox="0 0 200 260" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <%# Soil line %>
      <line x1="20" y1="220" x2="180" y2="220" class="plant-soil"/>
      <line x1="30" y1="230" x2="170" y2="230" class="plant-soil" stroke-opacity="0.4"/>

      <%# Stem — gentle S-curve from soil to crown %>
      <path d="M 100 220 C 96 180, 108 150, 100 110 S 92 60, 100 30"
            class="plant-stem"/>

      <%# Left leaf — teardrop %>
      <path d="M 100 130 C 70 120, 55 95, 60 70 C 80 80, 95 105, 100 130 Z"
            class="plant-leaf-l"/>

      <%# Right leaf — teardrop %>
      <path d="M 100 95 C 130 85, 145 60, 140 35 C 120 45, 105 70, 100 95 Z"
            class="plant-leaf-r"/>

      <%# Seed / crown dot + halo %>
      <circle cx="100" cy="28" r="6" class="plant-seed"/>
      <circle cx="100" cy="28" r="14" fill="none" stroke="#4a5538" stroke-opacity="0.18" stroke-width="1"/>
    </svg>
    <p class="eco-eyebrow center"><%= cms("footer_tagline", default: t("site.tagline", default: "Faith, Rewilded")) %></p>
  </div>

  <%# Oversized italic Ecosystem wordmark — pure decoration %>
  <span class="word" aria-hidden="true">Ecosystem</span>
</section>

<%# ── Footer (HANDOFF §2.13) ───────────────────────────────────────────── %>
<footer class="eco-footer">
  <div class="max-w-[1240px] mx-auto px-6 md:px-14">
    <div class="eco-footer-grid">
      <%# Brand %>
      <div class="eco-footer-col">
        <%= image_tag "/source-assets/logo.png",
                      alt: t("site.name"),
                      class: "h-16 md:h-20 w-auto opacity-90 mb-4" %>
        <p class="font-display italic text-[15px] leading-snug text-eco-ink-soft max-w-xs">
          <%= cms("footer_blurb", default: t("footer.blurb", default: "Jesus the Designer's Plan to change the world, kept in your hands — free.")) %>
        </p>
      </div>

      <%# Read %>
      <div class="eco-footer-col">
        <h4>Read</h4>
        <ul>
          <li><%= link_to t("nav.books"),      books_path %></li>
          <li><%= link_to t("nav.audiobooks"), audiobooks_path %></li>
        </ul>
      </div>

      <%# More %>
      <div class="eco-footer-col">
        <h4>More</h4>
        <ul>
          <li><%= link_to t("nav.about"),   about_path %></li>
          <li><%= link_to t("nav.contact"), contact_path %></li>
          <li><%= link_to t("nav.request"), request_free_copy_path %></li>
        </ul>
      </div>

      <%# Languages — pulls from the same `languages` CMS list as the header dropdown. %>
      <% footer_languages = cms_json("languages", default: [
           { "code" => "en", "name" => "English"   },
           { "code" => "es", "name" => "Español"   },
           { "code" => "pt", "name" => "Português" },
           { "code" => "fr", "name" => "Français"  },
           { "code" => "de", "name" => "Deutsch"   },
           { "code" => "it", "name" => "Italiano"  }
         ])
         footer_available = available_locales.map(&:to_s) %>
      <div class="eco-footer-col">
        <h4><%= t("footer.languages") %></h4>
        <ul>
          <% footer_languages.each do |entry| %>
            <% code   = entry["code"].to_s %>
            <% name   = entry["name"].to_s %>
            <% target = footer_available.include?(code) ? url_for(locale: code, only_path: true) : url_for(locale: I18n.default_locale, only_path: true) %>
            <li>
              <%= link_to target do %>
                <span class="font-mono text-[11px] tracking-[0.18em] text-eco-ink-soft mr-2"><%= code.upcase %></span>
                <span><%= name %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="eco-footer-bottom">
      <span>© <%= Date.current.year %> <%= t("site.name") %> · <%= t("footer.rights") %></span>
      <span>Crafted with care · Faith, Rewilded</span>
    </div>
  </div>
</footer>
