<footer class="relative border-t border-eco-border mt-32 overflow-hidden bg-eco-bg">

  <%# Plant emergence — the soul of the footer %>
  <div class="relative pt-28 pb-12">
    <%= render "shared/plant_emergence" %>
    <p class="text-center mt-6 eco-eyebrow"><%= cms("footer_tagline", default: t("site.tagline")) %></p>
  </div>

  <%# ─── Subscribe band ───────────────────────────────────────────────── %>
  <div class="relative max-w-5xl mx-auto px-6 pb-24">
    <div class="rounded-3xl border border-eco-border bg-eco-surface/60 backdrop-blur-xl p-10 md:p-14 text-center relative overflow-hidden">
      <div class="absolute -top-24 -left-24 size-[24rem] rounded-full bg-eco-green/10 blur-[100px] pointer-events-none"></div>
      <div class="absolute -bottom-20 -right-20 size-[20rem] rounded-full bg-eco-green/[0.08] blur-[90px] pointer-events-none"></div>

      <div class="relative">
        <p class="eco-eyebrow">— Newsletter</p>
        <h3 class="mt-4 font-display text-3xl md:text-5xl text-eco-white leading-[1.08]">
          <%= cms("subscribe_heading", default: "Get the next volume in your inbox") %>
        </h3>
        <p class="mt-4 text-eco-text-muted max-w-md mx-auto">
          <%= cms("subscribe_body", default: "Quarterly dispatches. No spam, ever.") %>
        </p>

        <div class="mt-10 max-w-md mx-auto">
          <%= render "shared/subscribe_form" %>
        </div>
      </div>
    </div>
  </div>

  <%# Outline word — editorial signature behind the columns %>
  <div class="absolute inset-x-0 bottom-32 text-center pointer-events-none select-none opacity-80">
    <h2 class="outline-word">Ecosystem</h2>
  </div>

  <div class="relative max-w-7xl mx-auto px-6 pt-12 pb-14 grid md:grid-cols-12 gap-12">
    <div class="md:col-span-4 space-y-4">
      <%= image_tag "/source-assets/logo.png",
                    alt: t("site.name"),
                    class: "h-12 w-auto opacity-90" %>
      <p class="font-display italic text-eco-text-muted text-lg max-w-xs">
        <%= cms("footer_tagline", default: t("site.tagline")) %>
      </p>
      <p class="text-eco-text-muted text-sm max-w-xs leading-relaxed">
        <%= cms("footer_manifesto", default: t("home.manifesto.three")) %>
      </p>
    </div>

    <div class="md:col-span-2">
      <p class="eco-eyebrow mb-4">Read</p>
      <ul class="space-y-2 text-sm">
        <li><%= link_to t("nav.books"),      books_path,      class: "text-eco-text/80 hover:text-eco-green-light transition" %></li>
        <li><%= link_to t("nav.audiobooks"), audiobooks_path, class: "text-eco-text/80 hover:text-eco-green-light transition" %></li>
      </ul>
    </div>

    <div class="md:col-span-2">
      <p class="eco-eyebrow mb-4">More</p>
      <ul class="space-y-2 text-sm">
        <li><%= link_to t("nav.about"),   "#",                    class: "text-eco-text/80 hover:text-eco-green-light transition" %></li>
        <li><%= link_to t("nav.contact"), "#",                    class: "text-eco-text/80 hover:text-eco-green-light transition" %></li>
        <li><%= link_to t("nav.request"), request_free_copy_path, class: "text-eco-text/80 hover:text-eco-green-light transition" %></li>
      </ul>
    </div>

    <div class="md:col-span-4">
      <p class="eco-eyebrow mb-4"><%= t("footer.languages") %></p>
      <%= render "shared/language_switcher" %>
      <p class="mt-6 text-xs text-eco-text-muted">
        © <%= Date.current.year %> <%= t("site.name") %>. <%= t("footer.rights") %>
      </p>
    </div>
  </div>
</footer>
