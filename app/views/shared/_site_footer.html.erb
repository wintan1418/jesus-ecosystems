<%# ── Sprout outro section (HANDOFF §2.12) ─────────────────────────────── %>
<section class="eco-sprout-outro">
  <div class="relative z-10">
    <%# Sprout SVG (stem + 2 leaves, sage tones) — 48px %>
    <svg class="sprout" viewBox="0 0 48 56" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M24 54 V20" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      <path d="M24 28 C18 24 12 22 8 22 C10 28 16 32 24 32" fill="currentColor" opacity=".75"/>
      <path d="M24 24 C30 18 36 16 40 16 C38 22 32 28 24 28" fill="currentColor" opacity=".9"/>
      <ellipse cx="24" cy="54" rx="14" ry="2" fill="currentColor" opacity=".15"/>
    </svg>
    <p class="eco-eyebrow center"><%= cms("footer_tagline", default: t("site.tagline", default: "Faith, Rewilded")) %></p>
  </div>

  <%# Oversized italic Ecosystem wordmark — pure decoration %>
  <span class="word" aria-hidden="true">Ecosystem</span>
</section>

<%# ── Footer (HANDOFF §2.13) ───────────────────────────────────────────── %>
<footer class="eco-footer">
  <div class="max-w-[1240px] mx-auto px-6 md:px-14">
    <div class="eco-footer-grid">
      <%# Brand %>
      <div class="eco-footer-col">
        <%= image_tag "/source-assets/logo.png",
                      alt: t("site.name"),
                      class: "h-9 w-auto opacity-90 mb-4" %>
        <p class="font-display italic text-[15px] leading-snug text-eco-ink-soft max-w-xs">
          <%= cms("footer_blurb", default: t("footer.blurb", default: "Jesus the Designer's Plan to change the world, kept in your hands — free.")) %>
        </p>
      </div>

      <%# Read %>
      <div class="eco-footer-col">
        <h4>Read</h4>
        <ul>
          <li><%= link_to t("nav.books"),      books_path %></li>
          <li><%= link_to t("nav.audiobooks"), audiobooks_path %></li>
        </ul>
      </div>

      <%# More %>
      <div class="eco-footer-col">
        <h4>More</h4>
        <ul>
          <li><%= link_to t("nav.about"),   about_path %></li>
          <li><%= link_to t("nav.contact"), contact_path %></li>
          <li><%= link_to t("nav.request"), request_free_copy_path %></li>
        </ul>
      </div>

      <%# Languages %>
      <div class="eco-footer-col">
        <h4><%= t("footer.languages") %></h4>
        <ul>
          <% available_locales.each do |loc| %>
            <li>
              <%= link_to url_for(locale: loc, only_path: true) do %>
                <span class="font-mono text-[11px] tracking-[0.18em] text-eco-ink-soft mr-2"><%= loc.to_s.upcase %></span>
                <span><%= { en: "English", es: "Español", pt: "Português" }[loc] || loc.to_s.upcase %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="eco-footer-bottom">
      <span>© <%= Date.current.year %> <%= t("site.name") %> · <%= t("footer.rights") %></span>
      <span>Crafted with care · Faith, Rewilded</span>
    </div>
  </div>
</footer>
