<%# Turbo Frame wrapping the form so success state replaces inline without a
    full page reload. %>
<%= turbo_frame_tag "subscribe_form" do %>
  <% if flash[:subscribed].present? %>
    <div class="rounded-full border border-eco-green/50 bg-eco-green-muted py-4 px-6 text-eco-green-light text-sm flex items-center justify-center gap-3">
      <span class="block size-2 rounded-full bg-eco-green pulse-dot"></span>
      <%= flash[:subscribed] %>
    </div>
  <% else %>
    <%= form_with url: subscribes_path, method: :post,
                  data: { turbo_frame: "subscribe_form", controller: "subscribe-form" },
                  class: "flex flex-col sm:flex-row gap-3 items-stretch" do |f| %>
      <%= f.email_field :email,
                        placeholder: "you@example.com",
                        required: true,
                        autocomplete: "email",
                        class: "flex-1 rounded-full border border-eco-border bg-eco-bg/60 backdrop-blur-md px-6 py-3.5 text-eco-white placeholder:text-eco-text-muted/50 focus:border-eco-green focus:outline-none focus:ring-2 focus:ring-eco-green/20 transition" %>
      <%= f.hidden_field :source, value: "footer" %>
      <%= f.hidden_field :locale, value: I18n.locale %>
      <%= f.submit "Subscribe →",
                   class: "eco-btn-primary text-sm whitespace-nowrap",
                   data: { disable_with: "Subscribing…" } %>
    <% end %>
    <% if flash[:subscribe_error].present? %>
      <p class="mt-3 text-xs text-red-300"><%= flash[:subscribe_error] %></p>
    <% end %>
  <% end %>
<% end %>
