<%
  shoutout_video  = SiteSetting["shoutout_video_url"].presence
  shoutout_poster = SiteSetting["shoutout_poster_url"].presence ||
                    "https://images.unsplash.com/photo-1507692049790-de58290a4334?w=1400&q=80&auto=format&fit=crop"
  shoutout_label  = SiteSetting["shoutout_label"].presence || "A word from the author"
  shoutout_cta    = SiteSetting["shoutout_cta"].presence   || "Play the message"

  testimonials = begin
    parsed = JSON.parse(SiteSetting["testimonials"].to_s)
    parsed.is_a?(Array) ? parsed : []
  rescue JSON::ParserError
    []
  end

  if testimonials.empty?
    testimonials = [
      { "quote" => t("home.quote"), "attribution" => t("home.quote_attribution") }
    ]
  end
%>

<section id="shoutout" data-rail-label="Voices"
         class="relative py-32 bg-eco-bg overflow-hidden">

  <div class="absolute -top-24 -right-24 size-[36rem] rounded-full bg-eco-green/10 blur-[140px] pointer-events-none"></div>
  <div class="absolute -bottom-32 -left-24 size-[32rem] rounded-full bg-eco-green/[0.06] blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 grid lg:grid-cols-[auto_1fr] gap-14 lg:gap-20 items-center">

    <%# ── LEFT: inline 9:16 vertical video panel ─────────────────────── %>
    <div class="shoutout-vertical-wrap" data-controller="reveal">
      <div class="flex items-center gap-4 mb-5">
        <span class="section-num">— 04</span>
        <p class="eco-eyebrow"><%= shoutout_label %></p>
      </div>

      <div class="shoutout-vertical">
        <% if shoutout_video.present? %>
          <video class="shoutout-vertical-video"
                 src="<%= shoutout_video %>"
                 <% if shoutout_poster.present? %>poster="<%= shoutout_poster %>"<% end %>
                 controls
                 playsinline
                 preload="metadata"
                 controlslist="nodownload"
                 aria-label="<%= shoutout_cta %>"></video>
        <% else %>
          <div class="shoutout-vertical-empty">
            <p class="eco-eyebrow text-eco-green-light">Coming soon</p>
            <p class="mt-3 font-display italic text-eco-white text-lg">
              The author's message is on the way.
            </p>
            <p class="mt-3 text-xs text-eco-text-muted">
              Drop the URL into <span class="font-mono text-eco-green-light">/admin/home → Shoutout video URL</span>.
            </p>
          </div>
        <% end %>
      </div>

      <p class="mt-4 font-mono text-[10px] tracking-[0.3em] uppercase text-eco-text-muted">
        <%= shoutout_cta %> · Vertical
      </p>
    </div>

    <%# ── RIGHT: testimonial rotator ─────────────────────────────────── %>
    <div class="testimonial-stack" data-controller="reveal">
      <div class="flex items-center gap-4 mb-6">
        <span class="section-num">— 05</span>
        <p class="eco-eyebrow">Voices</p>
      </div>

      <h3 class="font-display text-4xl md:text-5xl text-eco-white leading-[1.08] mb-8">
        Hear it<br>
        <span class="italic font-normal text-eco-green-light">from him directly.</span>
      </h3>

      <span class="mark">"</span>

      <div class="items"
           data-controller="tagline-rotator"
           data-tagline-rotator-interval-value="5000">
        <% testimonials.each do |t| %>
          <div data-tagline-rotator-target="item">
            <span class="q"><%= t["quote"] || t[:quote] %></span>
            <span class="a"><%= t["attribution"] || t[:attribution] %></span>
          </div>
        <% end %>
      </div>

      <div class="mt-6 flex items-center gap-3 text-[10px] tracking-[0.3em] uppercase text-eco-text-muted">
        <span class="block size-1.5 rounded-full bg-eco-green pulse-dot"></span>
        <span><%= testimonials.length %> voices · rotating</span>
      </div>
    </div>
  </div>
</section>
