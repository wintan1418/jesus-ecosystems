<!DOCTYPE html>
<html lang="<%= I18n.locale %>" class="bg-eco-cream" data-controller="cursor-spotlight scroll-progress">
  <head>
    <%= display_meta_tags(
          site:         t("site.name"),
          title:        content_for(:title).presence || cms("hero_headline_1", default: t("site.name")),
          reverse:      true,
          separator:    "·",
          description:  cms("hero_subhead", default: t("home.subhead", default: t("site.name"))),
          canonical:    request.original_url,
          og: {
            type:  "website",
            url:   request.original_url,
            site_name: t("site.name"),
            image: cms("og_image_url", default: "#{request.base_url}/source-assets/volume-1.jpg"),
            locale: I18n.locale.to_s
          },
          twitter: { card: "summary_large_image" }
        ) %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t('site.name') %>">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="theme-color" content="#D9D9CC">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= hreflang_tags %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&family=Caveat:wght@500;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-eco-cream text-eco-ink font-sans antialiased min-h-screen flex flex-col">
    <div class="scroll-progress"></div>
    <div class="cursor-spotlight"></div>

    <%# ── Page-wide colour palette toggle (client review tool) ── %>
    <div class="page-theme-toggle" data-controller="theme-toggle" aria-label="Choose page colour palette">
      <span class="page-theme-toggle-label">Palette</span>
      <button type="button"
              class="page-theme-swatch is-active"
              data-action="click->theme-toggle#pickA"
              data-theme-toggle-target="optionA"
              title="Cool Sage — #D9D9CC / #DED9D1">
        <span class="swatch" style="background:#D9D9CC;"></span>
        <span class="name">Cool Sage</span>
      </button>
      <button type="button"
              class="page-theme-swatch"
              data-action="click->theme-toggle#pickB"
              data-theme-toggle-target="optionB"
              title="Warm Cream — #f7f1df / #fbf6e6">
        <span class="swatch" style="background:#f7f1df;"></span>
        <span class="name">Warm Cream</span>
      </button>
    </div>

    <%= render "shared/site_header" %>
    <%= render "shared/section_rail" %>

    <main class="flex-1">
      <% if notice.present? %>
        <div class="max-w-6xl mx-auto px-6 mt-6 rounded-xl border border-eco-border bg-eco-surface px-5 py-3 text-eco-green-light">
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="max-w-6xl mx-auto px-6 mt-6 rounded-xl border border-red-500/30 bg-red-950/30 px-5 py-3 text-red-200">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <%= render "shared/site_footer" %>
  </body>
</html>
