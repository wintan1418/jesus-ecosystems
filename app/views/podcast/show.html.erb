<% content_for :title, "#{@episode.title} · #{cms('podcast_title', default: 'Podcast')}" %>

<article class="relative pt-36 pb-32 overflow-hidden bg-mesh">
  <div class="absolute -top-32 -left-32 size-[36rem] rounded-full bg-eco-green/10 blur-[140px] pointer-events-none"></div>

  <div class="relative max-w-3xl mx-auto px-6">
    <nav class="flex items-center gap-2 text-xs tracking-wider uppercase text-eco-text-muted mb-10">
      <%= link_to t("nav.home"),     root_path,     class: "hover:text-eco-green-light" %>
      <span>/</span>
      <%= link_to "Podcast",         podcast_path,  class: "hover:text-eco-green-light" %>
      <span>/</span>
      <span class="text-eco-green-light truncate"><%= @episode.label %></span>
    </nav>

    <header class="mb-12 space-y-6" data-controller="reveal">
      <p class="font-mono text-[10px] tracking-[0.3em] uppercase text-eco-green-light">
        <%= @episode.label %> · <%= @episode.published_at.strftime("%B %d, %Y") %> · <%= @episode.duration || "—" %>
      </p>

      <h1 class="font-display text-4xl md:text-6xl text-eco-white leading-[1.05]">
        <%= @episode.title %>
      </h1>

      <% if @episode.description.present? %>
        <p class="eco-subhead max-w-2xl"><%= @episode.description %></p>
      <% end %>

      <span class="block draw-line" style="width: 72px"></span>
    </header>

    <%# Audio player %>
    <div class="rounded-3xl border border-eco-border bg-eco-surface p-7 md:p-9 mb-12 flex items-center gap-6"
         data-controller="audio-player">
      <% if @episode.audio_file.attached? %>
        <button type="button"
                class="size-16 rounded-full bg-eco-green text-eco-bg flex items-center justify-center text-xl shadow-[0_12px_40px_-8px_rgba(163,191,100,0.6)] hover:scale-105 transition"
                data-action="click->audio-player#toggle"
                data-audio-player-target="playBtn">
          <span data-audio-player-target="playIcon">▶</span>
        </button>
        <div class="flex-1 min-w-0">
          <p class="text-xs text-eco-text-muted truncate" data-audio-player-target="title">
            <%= @episode.title %>
          </p>
          <div class="mt-3 h-1.5 rounded-full bg-eco-border overflow-hidden cursor-pointer relative"
               data-audio-player-target="progress"
               data-action="click->audio-player#seek">
            <div class="h-full bg-gradient-to-r from-eco-green to-eco-green-light"
                 data-audio-player-target="fill" style="width: 0"></div>
          </div>
          <div class="flex items-center justify-between mt-2 font-mono text-xs text-eco-text-muted">
            <span data-audio-player-target="elapsed">0:00</span>
            <span data-audio-player-target="remaining">-0:00</span>
          </div>
        </div>
        <audio data-audio-player-target="audio" preload="metadata"
               src="<%= url_for(@episode.audio_file) %>"></audio>
      <% else %>
        <p class="text-eco-text-muted italic font-display text-lg">— audio coming soon —</p>
      <% end %>
    </div>

    <%# Show notes %>
    <div class="prose-eco" data-controller="reveal">
      <%= @episode.body %>
    </div>

    <footer class="mt-16 pt-10 border-t border-eco-border flex items-center justify-between">
      <%= link_to podcast_path, class: "text-eco-text-muted hover:text-eco-green-light text-sm tracking-wider uppercase inline-flex items-center gap-2" do %>
        <span>←</span> All episodes
      <% end %>
      <%= link_to "Subscribe via RSS", podcast_rss_path, target: "_blank",
                  class: "eco-btn-ghost text-sm" %>
    </footer>
  </div>
</article>
