<% content_for :title, "#{cms('podcast_title', default: 'The Ecosystem Podcast')} · #{t('site.name')}" %>

<%
  cover         = cms("podcast_cover_url",
                       default: "https://images.unsplash.com/photo-1490127252417-7c393f993ee4?w=1400&q=80&auto=format&fit=crop")
  podcast_title = cms("podcast_title",    default: "The Ecosystem Podcast")
  subtitle      = cms("podcast_subtitle", default: "Field notes from the movement that refuses to be a system.")
  apple_url     = cms("podcast_apple_url",   default: nil)
  spotify_url   = cms("podcast_spotify_url", default: nil)
%>

<%# ─── Hero ─────────────────────────────────────────────────────────── %>
<section class="relative pt-36 pb-24 overflow-hidden bg-mesh">
  <div class="absolute -top-32 -left-32 size-[36rem] rounded-full bg-eco-green/10 blur-[140px] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 grid lg:grid-cols-12 gap-12 items-center">
    <%# Cover %>
    <div class="lg:col-span-5" data-controller="reveal">
      <div class="relative max-w-md mx-auto">
        <div class="aspect-square rounded-3xl overflow-hidden border border-eco-border eco-float shadow-[0_60px_120px_-30px_rgba(163,191,100,0.3)]">
          <img src="<%= cover %>" alt="<%= podcast_title %>" class="w-full h-full object-cover">
        </div>
        <div class="absolute -top-5 -left-5 size-20 rounded-full border border-eco-green/40 bg-eco-bg/70 backdrop-blur-md flex items-center justify-center">
          <span class="font-display italic text-eco-green-light text-sm text-center leading-tight">The<br>Podcast</span>
        </div>
      </div>
    </div>

    <%# Copy + subscribe links %>
    <div class="lg:col-span-7 space-y-7" data-controller="reveal">
      <p class="eco-eyebrow">— Listen anywhere</p>

      <h1 class="eco-display"><%= podcast_title %></h1>

      <span class="block draw-line" style="width: 72px"></span>

      <p class="eco-subhead max-w-xl"><%= subtitle %></p>

      <div class="flex flex-wrap items-center gap-3 pt-4">
        <% if apple_url.present? %>
          <%= link_to apple_url, target: "_blank", rel: "noopener",
                      class: "inline-flex items-center gap-2 rounded-full border border-eco-border bg-eco-surface px-5 py-2.5 text-sm text-eco-text hover:border-eco-green transition" do %>
            <span></span> Apple Podcasts
          <% end %>
        <% end %>
        <% if spotify_url.present? %>
          <%= link_to spotify_url, target: "_blank", rel: "noopener",
                      class: "inline-flex items-center gap-2 rounded-full border border-eco-border bg-eco-surface px-5 py-2.5 text-sm text-eco-text hover:border-eco-green transition" do %>
            <span>♫</span> Spotify
          <% end %>
        <% end %>
        <%= link_to podcast_rss_path, target: "_blank",
                    class: "inline-flex items-center gap-2 rounded-full border border-eco-border bg-eco-surface px-5 py-2.5 text-sm text-eco-text hover:border-eco-green transition" do %>
          <span>📡</span> RSS
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ─── Episodes list ───────────────────────────────────────────────── %>
<section class="max-w-5xl mx-auto px-6 pb-32">
  <% if @episodes.any? %>
    <ol class="space-y-4">
      <% @episodes.each_with_index do |ep, i| %>
        <%= link_to episode_path(ep.slug), class: "group block", data: { controller: "reveal" } do %>
          <article class="rounded-3xl border border-eco-border bg-eco-surface p-7 md:p-8 flex gap-6 items-start transition-all duration-500 hover:border-eco-green hover:-translate-y-0.5">
            <%# Number / cover %>
            <div class="shrink-0 size-20 md:size-24 rounded-2xl overflow-hidden bg-eco-bg flex items-center justify-center font-display italic text-eco-green-light text-3xl border border-eco-border">
              <% if ep.cover_image.attached? %>
                <%= image_tag ep.cover_image, class: "w-full h-full object-cover" %>
              <% else %>
                <%= ep.label %>
              <% end %>
            </div>

            <%# Body %>
            <div class="flex-1 min-w-0">
              <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-eco-text-muted">
                <%= ep.label %> · <%= ep.published_at.strftime("%b %-d, %Y") %> · <%= ep.duration || "—" %>
              </p>
              <h2 class="mt-2 font-display text-xl md:text-2xl text-eco-white group-hover:text-eco-green-light transition">
                <%= ep.title %>
              </h2>
              <% if ep.description.present? %>
                <p class="mt-3 text-eco-text-muted leading-relaxed line-clamp-2">
                  <%= ep.description %>
                </p>
              <% end %>
            </div>

            <%# Play affordance %>
            <span class="shrink-0 size-12 rounded-full bg-eco-green text-eco-bg flex items-center justify-center text-lg shadow-[0_8px_24px_-8px_rgba(163,191,100,0.6)] group-hover:scale-110 transition">▶</span>
          </article>
        <% end %>
      <% end %>
    </ol>
  <% else %>
    <div class="text-center py-24">
      <p class="font-display italic text-eco-text-muted text-2xl">— No episodes published yet.</p>
    </div>
  <% end %>
</section>
