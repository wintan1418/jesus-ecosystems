<% content_for :title, "#{t('free_copy.new.title')} · #{t('site.name')}" %>

<section class="relative pt-36 pb-32" style="background: var(--color-eco-cream);">
  <span class="eco-edge-label">— <%= t("free_copy.new.title") %></span>

  <%# Hero %>
  <div class="relative max-w-3xl mx-auto px-6 md:px-14 text-center mb-14" data-controller="reveal">
    <span class="eco-pill-eyebrow eco-pill-eyebrow--ink"><%= t("free_copy.new.hero_badge") %></span>
    <h1 class="mt-8 font-display text-[clamp(44px,7vw,78px)] leading-[1.02] text-eco-ink" style="font-weight: 600;">
      <%= t("free_copy.new.heading_1") %><br>
      <em style="font-weight: 400;"><%= t("free_copy.new.heading_2") %></em>
    </h1>
    <p class="mt-6 eco-subhead mx-auto" style="max-width: 540px;">
      <%= t("free_copy.new.subhead") %>
    </p>
  </div>

  <%# Form card %>
  <div class="relative max-w-3xl mx-auto px-6 md:px-14">
    <%= form_with model: @request, url: free_copy_requests_path,
                  data: { controller: "reveal" },
                  class: "rounded-[10px] p-8 md:p-12 space-y-10",
                  style: "background: var(--color-eco-paper); border: 1px solid var(--color-eco-rule); box-shadow: 0 30px 60px -30px rgba(42,47,32,.18);" do |f| %>

      <%# Validation errors %>
      <% if @request.errors.any? %>
        <div class="rounded-[10px] px-5 py-4 text-sm"
             style="border: 1px solid rgba(200,70,52,.4); background: rgba(200,70,52,.08); color: #8a2818;">
          <p class="font-medium mb-2"><%= t("free_copy.new.errors_heading") %></p>
          <ul class="list-disc list-inside space-y-1 text-xs opacity-90">
            <% @request.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Honeypot %>
      <div class="absolute opacity-0 pointer-events-none -left-[9999px]" aria-hidden="true">
        <label for="company_website">Leave this empty</label>
        <input type="text" id="company_website" name="company_website" tabindex="-1" autocomplete="off">
      </div>

      <%# ─── Name ─────────────────────────────────────────────────── %>
      <fieldset class="space-y-4">
        <legend class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2"><%= t("free_copy.new.legend_name") %></legend>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <%= f.label :first_name, t("free_copy.new.first_name"), class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :first_name, required: true, autocomplete: "given-name", class: "eco-input" %>
          </div>
          <div>
            <%= f.label :last_name, t("free_copy.new.last_name"), class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :last_name, required: true, autocomplete: "family-name", class: "eco-input" %>
          </div>
        </div>
      </fieldset>

      <%# ─── Email ────────────────────────────────────────────────── %>
      <fieldset class="space-y-4">
        <legend class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2"><%= t("free_copy.new.legend_email") %> <span class="normal-case text-eco-ink-soft ml-2"><%= t("free_copy.new.email_optional") %></span></legend>
        <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com", class: "eco-input" %>
        <p class="text-xs text-eco-ink-soft"><%= t("free_copy.new.email_helper") %></p>
      </fieldset>

      <%# ─── Address ──────────────────────────────────────────────── %>
      <fieldset class="space-y-4">
        <legend class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2"><%= t("free_copy.new.legend_address") %></legend>

        <div>
          <%= f.label :address_line_1, t("free_copy.new.street"), class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
          <%= f.text_field :address_line_1, required: true, autocomplete: "address-line1", class: "eco-input" %>
        </div>
        <div>
          <%= f.label :address_line_2, t("free_copy.new.street_2"), class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
          <%= f.text_field :address_line_2, autocomplete: "address-line2", class: "eco-input" %>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <%= f.label :city, t("free_copy.new.city"), class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :city, required: true, autocomplete: "address-level2", class: "eco-input" %>
          </div>
          <div>
            <%= f.label :state_province, t("free_copy.new.state"), class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :state_province, required: true, autocomplete: "address-level1", class: "eco-input" %>
          </div>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <%= f.label :postal_code, t("free_copy.new.postal"), class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :postal_code, required: true, autocomplete: "postal-code", class: "eco-input" %>
          </div>
          <div>
            <%= f.label :country, t("free_copy.new.country"), class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :country, required: true, autocomplete: "country-name", class: "eco-input" %>
          </div>
        </div>
      </fieldset>

      <%# ─── Books ────────────────────────────────────────────────── %>
      <fieldset class="space-y-5">
        <legend class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2"><%= t("free_copy.new.legend_books") %></legend>

        <%# Vol 1 Intro %>
        <div class="rounded-[10px] p-5 flex items-start gap-5"
             style="background: var(--color-eco-cream); border: 1px solid var(--color-eco-rule);">
          <div class="flex-1">
            <p class="font-display text-lg text-eco-ink" style="font-weight: 500;"><%= t("free_copy.new.vol1_title") %></p>
            <p class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mt-1"><%= t("free_copy.new.vol1_meta") %></p>
            <p class="text-[13px] text-eco-ink-soft mt-2"><%= t("free_copy.new.vol1_blurb") %></p>
          </div>
          <div class="w-24">
            <%= f.label :qty_vol_1, t("free_copy.new.qty"), class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2 text-center" %>
            <%= f.number_field :qty_vol_1, min: 0, max: 50, class: "eco-input text-center text-lg font-display" %>
          </div>
        </div>

        <%# Vol 1 + 2 Combo %>
        <div class="rounded-[10px] p-5 flex items-start gap-5"
             style="background: rgba(138, 154, 104, 0.10); border: 1px solid rgba(90, 107, 72, 0.4);">
          <div class="flex-1">
            <p class="font-display text-lg text-eco-ink" style="font-weight: 500;"><%= t("free_copy.new.combo_title") %></p>
            <p class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-olive-deep mt-1"><%= t("free_copy.new.combo_meta") %></p>
            <p class="text-[13px] text-eco-ink-soft mt-2"><%= t("free_copy.new.combo_blurb") %></p>
          </div>
          <div class="w-24">
            <%= f.label :qty_vol_1_combo, t("free_copy.new.qty"), class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2 text-center" %>
            <%= f.number_field :qty_vol_1_combo, min: 0, max: 50, class: "eco-input text-center text-lg font-display" %>
          </div>
        </div>
      </fieldset>

      <%# ─── Special requests ───────────────────────────────────── %>
      <fieldset class="space-y-4">
        <legend class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2"><%= t("free_copy.new.legend_notes") %></legend>
        <%= f.text_area :notes, rows: 4,
                        placeholder: t("free_copy.new.notes_placeholder"),
                        class: "eco-input" %>
      </fieldset>

      <%# Submit %>
      <div class="pt-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"
           style="border-top: 1px solid var(--color-eco-rule);">
        <p class="text-xs text-eco-ink-soft">
          <%= t("free_copy.new.submit_helper") %>
        </p>
        <%= f.submit t("free_copy.new.submit"),
                     class: "eco-btn-primary whitespace-nowrap",
                     data: { disable_with: t("free_copy.new.submit_busy") } %>
      </div>
    <% end %>
  </div>
</section>
