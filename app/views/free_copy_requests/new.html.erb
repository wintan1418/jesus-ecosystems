<% content_for :title, "Request free hardcopies · #{t('site.name')}" %>

<section class="relative pt-36 pb-32" style="background: var(--color-eco-cream);">
  <span class="eco-edge-label">— Request</span>

  <%# Hero %>
  <div class="relative max-w-3xl mx-auto px-6 md:px-14 text-center mb-14" data-controller="reveal">
    <span class="eco-pill-eyebrow eco-pill-eyebrow--ink">✦ 100% Free · Worldwide Shipping ✦</span>
    <h1 class="mt-8 font-display text-[clamp(44px,7vw,78px)] leading-[1.02] text-eco-ink" style="font-weight: 600;">
      Request free<br>
      <em style="font-weight: 400;">hardcopies.</em>
    </h1>
    <p class="mt-6 eco-subhead mx-auto" style="max-width: 540px;">
      Tell us where to ship. We pay the postage. The books are yours.
    </p>
  </div>

  <%# Form card %>
  <div class="relative max-w-3xl mx-auto px-6 md:px-14">
    <%= form_with model: @request, url: free_copy_requests_path,
                  data: { controller: "reveal" },
                  class: "rounded-[10px] p-8 md:p-12 space-y-10",
                  style: "background: var(--color-eco-paper); border: 1px solid var(--color-eco-rule); box-shadow: 0 30px 60px -30px rgba(42,47,32,.18);" do |f| %>

      <%# Validation errors %>
      <% if @request.errors.any? %>
        <div class="rounded-[10px] px-5 py-4 text-sm"
             style="border: 1px solid rgba(200,70,52,.4); background: rgba(200,70,52,.08); color: #8a2818;">
          <p class="font-medium mb-2">Please fix:</p>
          <ul class="list-disc list-inside space-y-1 text-xs opacity-90">
            <% @request.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%# Honeypot %>
      <div class="absolute opacity-0 pointer-events-none -left-[9999px]" aria-hidden="true">
        <label for="company_website">Leave this empty</label>
        <input type="text" id="company_website" name="company_website" tabindex="-1" autocomplete="off">
      </div>

      <%# ─── Name ─────────────────────────────────────────────────── %>
      <fieldset class="space-y-4">
        <legend class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2">— 01 · Name</legend>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <%= f.label :first_name, "First name *", class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :first_name, required: true, autocomplete: "given-name", class: "eco-input" %>
          </div>
          <div>
            <%= f.label :last_name, "Last name *", class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :last_name, required: true, autocomplete: "family-name", class: "eco-input" %>
          </div>
        </div>
      </fieldset>

      <%# ─── Email ────────────────────────────────────────────────── %>
      <fieldset class="space-y-4">
        <legend class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2">— 02 · Email <span class="normal-case text-eco-ink-soft ml-2">(optional)</span></legend>
        <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com", class: "eco-input" %>
        <p class="text-xs text-eco-ink-soft">If you'd like a shipping confirmation. Otherwise, we'll just send the books.</p>
      </fieldset>

      <%# ─── Address ──────────────────────────────────────────────── %>
      <fieldset class="space-y-4">
        <legend class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2">— 03 · Shipping address</legend>

        <div>
          <%= f.label :address_line_1, "Street address *", class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
          <%= f.text_field :address_line_1, required: true, autocomplete: "address-line1", class: "eco-input" %>
        </div>
        <div>
          <%= f.label :address_line_2, "Address line 2", class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
          <%= f.text_field :address_line_2, autocomplete: "address-line2", class: "eco-input" %>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <%= f.label :city, "City *", class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :city, required: true, autocomplete: "address-level2", class: "eco-input" %>
          </div>
          <div>
            <%= f.label :state_province, "State / Province / Region *", class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :state_province, required: true, autocomplete: "address-level1", class: "eco-input" %>
          </div>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <%= f.label :postal_code, "Postal / ZIP *", class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :postal_code, required: true, autocomplete: "postal-code", class: "eco-input" %>
          </div>
          <div>
            <%= f.label :country, "Country *", class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2" %>
            <%= f.text_field :country, required: true, autocomplete: "country-name", class: "eco-input" %>
          </div>
        </div>
      </fieldset>

      <%# ─── Books ────────────────────────────────────────────────── %>
      <fieldset class="space-y-5">
        <legend class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2">— 04 · How many books? *</legend>

        <%# Vol 1 Intro %>
        <div class="rounded-[10px] p-5 flex items-start gap-5"
             style="background: var(--color-eco-cream); border: 1px solid var(--color-eco-rule);">
          <div class="flex-1">
            <p class="font-display text-lg text-eco-ink" style="font-weight: 500;">Vol. 1 · Intro</p>
            <p class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mt-1">40 pages · FREE</p>
            <p class="text-[13px] text-eco-ink-soft mt-2">A short on-ramp to the ecosystem.</p>
          </div>
          <div class="w-24">
            <%= f.label :qty_vol_1, "Qty", class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2 text-center" %>
            <%= f.number_field :qty_vol_1, min: 0, max: 50, class: "eco-input text-center text-lg font-display" %>
          </div>
        </div>

        <%# Vol 1 + 2 Combo %>
        <div class="rounded-[10px] p-5 flex items-start gap-5"
             style="background: rgba(138, 154, 104, 0.10); border: 1px solid rgba(90, 107, 72, 0.4);">
          <div class="flex-1">
            <p class="font-display text-lg text-eco-ink" style="font-weight: 500;">Vol. 1 & 2 · Combined</p>
            <p class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-olive-deep mt-1">240 pages · FREE</p>
            <p class="text-[13px] text-eco-ink-soft mt-2">The full ecosystem story, both volumes bundled.</p>
          </div>
          <div class="w-24">
            <%= f.label :qty_vol_1_combo, "Qty", class: "block font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2 text-center" %>
            <%= f.number_field :qty_vol_1_combo, min: 0, max: 50, class: "eco-input text-center text-lg font-display" %>
          </div>
        </div>
      </fieldset>

      <%# ─── Special requests ───────────────────────────────────── %>
      <fieldset class="space-y-4">
        <legend class="font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-2">— 05 · Special requests</legend>
        <%= f.text_area :notes, rows: 4,
                        placeholder: "Need extra books for a study group? A specific delivery date? Tell us here.",
                        class: "eco-input" %>
      </fieldset>

      <%# Submit %>
      <div class="pt-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"
           style="border-top: 1px solid var(--color-eco-rule);">
        <p class="text-xs text-eco-ink-soft">
          By submitting, you agree to share your shipping details so we can mail the books.
        </p>
        <%= f.submit "Send the books →",
                     class: "eco-btn-primary whitespace-nowrap",
                     data: { disable_with: "Sending…" } %>
      </div>
    <% end %>
  </div>
</section>
