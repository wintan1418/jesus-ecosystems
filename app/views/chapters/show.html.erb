<% content_for :title, "#{@chapter.title} · #{@book.localized_title(I18n.locale)}" %>

<article class="relative max-w-3xl mx-auto px-6 pt-40 pb-32" style="background: var(--color-eco-cream);">
  <nav class="flex items-center gap-2 font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft mb-12">
    <%= link_to t("nav.home"),  root_path,                class: "hover:text-eco-ink" %>
    <span>/</span>
    <%= link_to t("nav.books"), books_path,               class: "hover:text-eco-ink" %>
    <span>/</span>
    <%= link_to "Vol. #{@book.volume_number}", book_path(@book.slug), class: "hover:text-eco-ink" %>
    <span>/</span>
    <span class="text-eco-ink truncate"><%= @chapter.title %></span>
  </nav>

  <header class="mb-16 space-y-6" data-controller="reveal">
    <p class="eco-eyebrow"><%= t("chapters.show.preview_badge") %></p>

    <div class="flex items-baseline gap-6">
      <span class="font-display italic text-eco-olive-deep text-5xl shrink-0" style="font-weight: 400;">
        <%= "%02d" % @chapter.position %>
      </span>
      <h1 class="font-display text-4xl md:text-6xl text-eco-ink leading-[1.05]" style="font-weight: 600;">
        <%= @chapter.title %>
      </h1>
    </div>
  </header>

  <div class="prose-eco" data-controller="reveal">
    <% if @chapter.body.body.present? %>
      <%= @chapter.body %>
    <% else %>
      <p class="text-eco-ink-soft italic">— No body content yet.</p>
    <% end %>
  </div>

  <footer class="mt-20 pt-10 flex items-center justify-between"
          style="border-top: 1px solid var(--color-eco-rule);">
    <%= link_to book_path(@book.slug), class: "font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft hover:text-eco-ink inline-flex items-center gap-2" do %>
      <span aria-hidden="true">←</span> <%= t("chapters.show.back") %>
    <% end %>
    <%= link_to t("home.cta_request"), request_free_copy_path, class: "eco-btn-primary", data: { controller: "magnetic" } %>
  </footer>
</article>

<%# Sticky mini-CTA — fades in past 30% scroll (driven by --scroll-progress) %>
<%= link_to request_free_copy_path, class: "eco-chapter-cta" do %>
  <span><%= t("home.cta_request") %></span>
  <span aria-hidden="true">→</span>
<% end %>
