<% content_for :title, "#{t('contact.title')} · #{t('site.name')}" %>

<section class="relative pt-40 pb-32" style="background: var(--color-eco-cream);">
  <div class="max-w-3xl mx-auto px-6 text-center" data-controller="reveal">
    <p class="eco-eyebrow center"><%= t("contact.eyebrow") %></p>
    <h1 class="font-display text-[clamp(48px,7vw,78px)] leading-[1.05] mt-5 text-eco-ink">
      <%= t("contact.heading") %>
    </h1>
    <p class="mt-6 eco-subhead mx-auto" style="max-width: 520px;">
      <%= t("contact.subhead") %>
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
      <%= link_to t("contact.cta_request"), request_free_copy_path, class: "eco-btn-primary" %>
      <%= link_to t("contact.cta_listen"),  audiobooks_path,        class: "eco-btn-ghost" %>
    </div>
  </div>
</section>
