<% content_for :title, "#{t('about.title')} · #{t('site.name')}" %>

<%# ─── Author hero (cream) ──────────────────────────────────────────── %>
<section class="relative pt-40 pb-32 overflow-hidden" style="background: var(--color-eco-cream);">
  <span class="eco-edge-label">— About</span>

  <div class="relative max-w-[1240px] mx-auto px-6 md:px-14 grid lg:grid-cols-12 gap-14 items-center">
    <%# Photo %>
    <div class="lg:col-span-5" data-controller="reveal">
      <div class="relative max-w-md mx-auto lg:mx-0">
        <div class="aspect-[4/5] rounded-md overflow-hidden"
             style="box-shadow: 0 30px 60px -30px rgba(42, 47, 32, 0.35); border: 1px solid var(--color-eco-rule);">
          <img src="<%= cms('author_photo_url', default: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=800&q=80') %>"
               alt="<%= cms('author_name', default: t('about.author_badge')) %>"
               class="w-full h-full object-cover"
               loading="lazy">
        </div>
        <div class="absolute -top-5 -left-5 size-24 rounded-full flex items-center justify-center"
             style="background: var(--color-eco-paper); border: 1px solid var(--color-eco-rule); box-shadow: 0 12px 24px -10px rgba(42,47,32,.18);">
          <span class="font-display italic text-eco-ink-soft text-sm text-center leading-tight"><%= t("about.author_badge").gsub(/\s+/, "<br>").html_safe %></span>
        </div>
      </div>
    </div>

    <%# Copy %>
    <div class="lg:col-span-7 space-y-7" data-controller="reveal">
      <p class="eco-eyebrow"><%= t("about.eyebrow") %></p>

      <h1 class="font-display text-[clamp(44px,6vw,74px)] leading-[1.02] text-eco-ink" style="font-weight: 600;">
        <%= cms("author_name", default: t("about.default_name")) %>
      </h1>

      <p class="font-display italic text-2xl md:text-3xl text-eco-olive-deep" style="font-weight: 400;">
        <%= cms("author_title", default: t("about.default_title")) %>
      </p>

      <p class="eco-subhead" style="max-width: 580px;">
        <%= cms("author_bio", default: t("about.default_bio")) %>
      </p>

      <% if SiteSetting["author_quote"].present? %>
        <blockquote class="font-display italic text-2xl md:text-3xl pl-6 max-w-xl leading-snug"
                    style="color: var(--color-eco-ink); border-left: 2px solid var(--color-eco-olive);">
          "<%= cms('author_quote') %>"
        </blockquote>
      <% end %>

      <div class="flex flex-wrap items-center gap-4 pt-2">
        <%= link_to t("about.cta_request"), request_free_copy_path, class: "eco-btn-primary" %>
        <%= link_to t("about.cta_listen"),  audiobooks_path,        class: "eco-btn-ghost" %>
      </div>
    </div>
  </div>
</section>

<%# ─── The journey (paper) ──────────────────────────────────────────── %>
<% if SiteSetting["author_journey"].present? %>
  <section class="relative" style="background: var(--color-eco-paper);">
    <div class="max-w-4xl mx-auto px-6 md:px-14 py-32">
      <div class="flex items-center gap-4 mb-10" data-controller="reveal">
        <span class="section-num"><%= t("about.journey_eyebrow") %></span>
      </div>
      <p class="font-display text-2xl md:text-4xl leading-[1.3] text-eco-ink max-w-3xl" data-controller="reveal">
        <%= cms("author_journey") %>
      </p>
    </div>
  </section>
<% end %>

<%# ─── CTA back to the books / free copies ─────────────────────── %>
<section class="max-w-3xl mx-auto px-6 py-32 text-center" data-controller="reveal" style="background: var(--color-eco-cream);">
  <p class="eco-eyebrow center"><%= t("about.cta_eyebrow") %></p>
  <h2 class="mt-6 font-display text-4xl md:text-6xl text-eco-ink leading-tight" style="font-weight: 500;">
    <%= t("about.cta_heading_html").html_safe %>
  </h2>
  <p class="mt-5 text-eco-ink-soft max-w-md mx-auto text-[15px]">
    <%= t("about.cta_body") %>
  </p>
  <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
    <%= link_to t("about.cta_request"), request_free_copy_path, class: "eco-btn-primary" %>
    <%= link_to t("about.cta_listen"),  audiobooks_path,        class: "eco-btn-ghost" %>
  </div>
</section>
