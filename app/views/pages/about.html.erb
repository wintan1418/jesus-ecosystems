<% content_for :title, "About · #{t('site.name')}" %>

<%# ─── Author hero ──────────────────────────────────────────────────── %>
<section class="relative pt-40 pb-32 overflow-hidden bg-mesh">
  <div class="absolute -top-32 -left-32 size-[36rem] rounded-full bg-eco-green/10 blur-[140px] pointer-events-none"></div>
  <div class="absolute -bottom-40 right-0 size-[28rem] rounded-full bg-eco-green/[0.08] blur-[120px] pointer-events-none"></div>

  <div class="relative max-w-6xl mx-auto px-6 grid lg:grid-cols-12 gap-14 items-center">
    <%# Photo %>
    <div class="lg:col-span-5" data-controller="reveal">
      <div class="relative max-w-md mx-auto lg:mx-0">
        <div class="aspect-[4/5] rounded-3xl overflow-hidden border border-eco-border eco-float shadow-[0_60px_120px_-30px_rgba(163,191,100,0.3)]">
          <img src="<%= cms('author_photo_url', default: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=800&q=80') %>"
               alt="<%= cms('author_name', default: 'The author') %>"
               class="w-full h-full object-cover">
        </div>
        <div class="absolute -top-5 -left-5 size-24 rounded-full border border-eco-green/40 bg-eco-bg/70 backdrop-blur-md flex items-center justify-center">
          <span class="font-display italic text-eco-green-light text-sm text-center leading-tight">The<br>Author</span>
        </div>
      </div>
    </div>

    <%# Copy %>
    <div class="lg:col-span-7 space-y-7" data-controller="reveal">
      <p class="eco-eyebrow">— Who writes this</p>

      <h1 class="eco-display">
        <%= cms("author_name", default: "SystemOrEcosystem") %>
      </h1>

      <p class="font-display italic text-eco-green-light text-xl md:text-2xl">
        <%= cms("author_title", default: "Author · Builder · Witness") %>
      </p>

      <span class="block draw-line" style="width: 72px"></span>

      <p class="eco-subhead max-w-xl">
        <%= cms("author_bio", default: "Writing about Jesus the way a gardener talks about soil.") %>
      </p>

      <% if SiteSetting["author_quote"].present? %>
        <blockquote class="font-display italic text-2xl md:text-3xl text-eco-white border-l-2 border-eco-green pl-6 max-w-xl leading-snug">
          "<%= cms('author_quote') %>"
        </blockquote>
      <% end %>

      <div class="flex flex-wrap items-center gap-4 pt-2">
        <%= link_to "Read the journal", journal_path, class: "eco-btn-primary text-sm" %>
        <%= link_to "Request free copies", request_free_copy_path, class: "eco-btn-ghost text-sm" %>
      </div>
    </div>
  </div>
</section>

<%# ─── The journey ─────────────────────────────────────────────────── %>
<% if SiteSetting["author_journey"].present? %>
  <section class="border-y border-eco-border bg-eco-surface/30">
    <div class="max-w-4xl mx-auto px-6 py-32">
      <div class="flex items-center gap-4 mb-8" data-controller="reveal">
        <span class="section-num">— 01</span>
        <p class="eco-eyebrow">The journey</p>
      </div>
      <p class="font-display text-2xl md:text-4xl text-eco-white leading-[1.3] max-w-3xl" data-controller="reveal">
        <%= cms("author_journey") %>
      </p>
    </div>
  </section>
<% end %>

<%# ─── Recent journal posts ───────────────────────────────────────── %>
<% if @recent_posts.any? %>
  <section class="max-w-5xl mx-auto px-6 py-32">
    <div class="flex items-end justify-between flex-wrap gap-6 mb-16" data-controller="reveal">
      <div>
        <div class="flex items-center gap-4 mb-4">
          <span class="section-num">— 02</span>
          <p class="eco-eyebrow">Latest from the journal</p>
        </div>
        <h2 class="font-display text-4xl md:text-6xl text-eco-white leading-tight">
          Field notes.
        </h2>
      </div>
      <%= link_to "All entries →", journal_path, class: "text-xs tracking-[0.25em] uppercase text-eco-green-light hover:text-eco-green transition" %>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      <% @recent_posts.each do |post| %>
        <%= link_to post_path(post.slug), class: "group block", data: { controller: "reveal" } do %>
          <article class="h-full rounded-2xl border border-eco-border bg-eco-surface p-7 transition-all duration-500 hover:border-eco-green hover:-translate-y-1">
            <p class="font-mono text-[10px] tracking-[0.25em] uppercase text-eco-text-muted">
              <%= post.published_at.strftime("%b %-d, %Y") %> · <%= post.reading_time %>
            </p>
            <h3 class="mt-4 font-display text-xl text-eco-white leading-tight group-hover:text-eco-green-light transition">
              <%= post.title %>
            </h3>
            <% if post.excerpt.present? %>
              <p class="mt-3 text-sm text-eco-text-muted leading-relaxed line-clamp-3">
                <%= post.excerpt %>
              </p>
            <% end %>
            <span class="mt-6 inline-flex items-center text-eco-green text-xs tracking-[0.2em] uppercase gap-2 group-hover:gap-4 transition-all">
              Read <span>→</span>
            </span>
          </article>
        <% end %>
      <% end %>
    </div>
  </section>
<% end %>
