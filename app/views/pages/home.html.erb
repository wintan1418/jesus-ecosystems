<% content_for :title, "#{cms('hero_headline_1', default: t('home.headline_1'))} · #{t('site.name')}" %>

<%
  hero_video      = cms("hero_video_url", default: "https://cdn.jwplayer.com/manifests/zKhUkn1D.m3u8")
  shoutout_video  = "https://res.cloudinary.com/wintan1418/video/upload/v1776372521/shout-out_ezrcu0.mp4"
  shoutout_poster = "https://res.cloudinary.com/wintan1418/image/upload/v1776374891/veritcal_banner_w7qc11.png"

  hero_slides = [
    "photo-1438232992991-995b7058bbb3",
    "photo-1469571486292-0ba58a3f068b",
    "photo-1507692049790-de58290a4334",
    "photo-1490127252417-7c393f993ee4",
    "photo-1466442929976-97f336a657be",
  ].map { |id| "https://images.unsplash.com/#{id}?w=1600&q=80&auto=format&fit=crop" }

  manifesto_image = "https://images.unsplash.com/photo-1455218873509-8097305ee378?w=1800&q=80&auto=format&fit=crop"
  cta_image       = "https://images.unsplash.com/photo-1444703686981-a3abbc4d4fe3?w=1800&q=80&auto=format&fit=crop"

  pillar_images = {
    "one"   => "https://images.unsplash.com/photo-1571175443880-49e1d25b2bc5?w=900&q=80&auto=format&fit=crop",
    "two"   => "https://images.unsplash.com/photo-1485463611174-f302f6a5c1c9?w=900&q=80&auto=format&fit=crop",
    "three" => "https://images.unsplash.com/photo-1542816417-0983c9c9ad53?w=900&q=80&auto=format&fit=crop",
    "four"  => "https://images.unsplash.com/photo-1500380804539-4e1e8c1e7118?w=900&q=80&auto=format&fit=crop",
  }
%>

<%# ─── 01 · HERO (togglable background) ─────────────────────────────────── %>
<section id="hero" data-rail-label="Intro"
         class="relative pt-32 pb-20 md:pt-36 md:pb-24"
         style="background: var(--color-eco-cream);">

  <%# Andrew 2026-05-18 (round 3): tip the grid toward the video so it actually
      grows — the previous 1.05fr/1fr capped the right column at ~520px and made
      the max-w-[900px] on the hero card meaningless. %>
  <div class="max-w-[1360px] mx-auto px-6 md:px-14 grid lg:grid-cols-[1fr_1.4fr] gap-10 lg:gap-16 items-center">

    <%# Left column %>
    <div class="space-y-6 min-w-0">
      <p class="eco-eyebrow"><%= cms("hero_eyebrow", default: t("home.eyebrow")) %></p>

      <h1 class="eco-display" data-controller="char-reveal" data-char-reveal-mode-value="word" data-char-reveal-stagger-value="120">
        <%= cms_lines("hero_headline_1", default: "Jesus the\nDesigner's Plan") %><br>
        <span class="it"><%= cms_lines("hero_headline_2", default: "to Change\nthe World.") %></span>
      </h1>

      <p class="eco-subhead">
        <%= cms("hero_subhead", default: t("home.subhead")) %>
      </p>

      <p class="font-display italic text-[18px] text-eco-ink max-w-[430px]">
        “<%= t("home.rotators").first %>”<span style="color: var(--color-eco-olive); margin-left: 8px;">✦</span>
      </p>

      <div class="flex flex-wrap items-center gap-5 pt-2">
        <%= link_to cms("hero_cta_primary", default: t("home.cta_request")), request_free_copy_path, class: "eco-btn-primary", data: { controller: "magnetic" } %>
        <%= link_to audiobooks_path, class: "eco-play-link" do %>
          <span class="pdot"></span><%= cms("hero_cta_ghost", default: t("home.cta_listen")) %>
        <% end %>
      </div>
    </div>

    <%# Right column — hero card with HLS video %>
    <div class="relative w-full min-w-0" data-controller="reveal">
      <%# Andrew 2026-05-18 (round 3): video bigger, all text overlays gone —
          no fake browser chrome, no corner timestamps, no italic wordmark.
          Just the clean video inside the sage rounded frame. %>
      <div class="eco-hero-card w-full mx-auto"
           data-controller="hls-video"
           data-hls-video-src-value="<%= hero_video %>">

        <%# Stage — slideshow as poster, video on top when playing %>
        <div class="stage">
          <div data-controller="ken-burns" class="ken-burns-stage">
            <% hero_slides.each_with_index do |url, i| %>
              <div class="hero-slide"
                   data-ken-burns-target="slide"
                   style="background-image: url('<%= url %>')"
                   <%= 'data-active="true"'.html_safe if i.zero? %>></div>
            <% end %>
          </div>

          <video class="hero-video"
                 data-hls-video-target="video"
                 muted playsinline preload="metadata" disablepictureinpicture></video>
        </div>

        <%# Cream play FAB — also unmutes %>
        <button class="play-fab"
                data-action="click->hls-video#toggleMute"
                data-hls-video-target="muteIcon"
                aria-label="Play"></button>
      </div>
    </div>
  </div>
</section>

<%# ─── 02 · STATS BAND (sage olive) ────────────────────────────────────── %>
<section id="stats" data-rail-label="Stats" class="eco-stats-band relative">
  <div class="max-w-[1240px] mx-auto px-6 md:px-14">
    <div class="eco-stats-grid">
      <%# Andrew 2026-05-18 (round 3): dropped the ° suffix on the 4th stat — just 360. %>
      <% [
        { to: 2,    suffix: "",  label: t("home.stats.volumes") },
        { to: 3,    suffix: "",  label: t("home.stats.languages") },
        { to: 100,  suffix: "%", label: t("free_copy.badge") },
        { to: 360,  suffix: "",  label: t("home.pillars_title") },
      ].each do |c| %>
        <div class="stat" data-controller="counter"
             data-counter-to-value="<%= c[:to] %>"
             data-counter-suffix-value="<%= c[:suffix] %>">
          <p class="num">
            <span data-counter-target="value">0</span>
          </p>
          <p class="lab"><%= c[:label] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ─── 03 · MARQUEE (olive-deep) ───────────────────────────────────────── %>
<section class="eco-marquee relative" data-controller="marquee">
  <%
    phrases = [
      "from struggling to legendary",
      "from needy to noteworthy",
      "from mundane to mountain-movers",
      "from chaos to community",
    ]
  %>
  <div class="eco-marquee-track" data-marquee-target="track">
    <% 2.times do %>
      <% phrases.each do |p| %>
        <span><%= p %></span>
        <span class="sep">✦</span>
      <% end %>
    <% end %>
  </div>
</section>

<%# ─── 04 · MANIFESTO (forest with parallax photo) ─────────────────────── %>
<section id="manifesto" data-rail-label="Manifesto" class="eco-manifesto" data-controller="parallax">
  <%# Parallax forest landscape under a green wash %>
  <div class="absolute inset-0 z-0 opacity-55"
       data-parallax-target="layer"
       data-depth="0.4"
       style="background-image: url('<%= manifesto_image %>'); background-size: cover; background-position: center;"></div>
  <div class="absolute inset-0 z-0"
       style="background: linear-gradient(180deg, rgba(74,85,56,0.78) 0%, rgba(74,85,56,0.55) 50%, rgba(74,85,56,0.85) 100%);"></div>

  <div class="inner max-w-[760px] mx-auto px-6 relative z-10">
    <p class="eco-eyebrow center light">Faith, Rewilded</p>
    <h2>
      The way Jesus builds <em>world-changers</em> hasn't aged a day.
      He refines ordinary people for <em>Jesus-sized outcomes.</em>
      This is a raw and honest look at how Jesus turns chaos into His community.
    </h2>

    <div class="points">
      <div class="eco-point" data-controller="reveal">
        <b>Jesus doesn't fund systems the gospel stories show.</b>
        Jesus rebuilds what structure forgot. Faith rewilded.
      </div>
      <div class="eco-point" data-controller="reveal">
        <b>Where faith stops performing and starts breathing.</b>
        Down to the original text — not free-text editing.
      </div>
      <div class="eco-point" data-controller="reveal">
        <b>He refines ordinary people for Jesus-sized outcomes.</b>
        From algorithm to organism.
      </div>
      <div class="eco-point" data-controller="reveal">
        <b>Religion is typically about a club, a vibe, and rules.</b>
        Jesus came to blow that up.
      </div>
    </div>
  </div>
</section>

<%# ─── 05 · HEAR IT (paper) ────────────────────────────────────────────── %>
<section id="hear" data-rail-label="Hear It" class="relative" style="background: var(--color-eco-paper); padding: 110px 0;">
  <div class="max-w-[1240px] mx-auto px-6 md:px-14 eco-hear-grid">

    <%# Left — 16:9 horizontal poster opens vertical video in a lightbox.
        (Andrew 2026-05-18: thumbnail must be 16:9, video popup stays vertical.) %>
    <div data-controller="reveal shoutout-lightbox" class="shoutout-thumb-wrap">
      <button type="button"
              class="shoutout-thumb"
              data-action="click->shoutout-lightbox#open"
              aria-label="Play the message">
        <img class="shoutout-poster"
             src="<%= shoutout_poster %>"
             alt="A word from the author">
        <span class="shoutout-play-badge">
          <span class="shoutout-play-icon">▶</span>
        </span>
      </button>
      <%# Vertical-video lightbox %>
      <dialog class="shoutout-dialog"
              data-shoutout-lightbox-target="dialog"
              data-action="click->shoutout-lightbox#backdropClose">
        <div class="shoutout-dialog-inner">
          <button type="button"
                  class="shoutout-dialog-close"
                  data-action="click->shoutout-lightbox#close"
                  aria-label="Close">&times;</button>
          <video class="shoutout-dialog-video"
                 src="<%= shoutout_video %>"
                 playsinline
                 preload="metadata"
                 controls
                 controlslist="nodownload"
                 data-shoutout-lightbox-target="video"></video>
        </div>
      </dialog>
    </div>

    <%# Right — copy %>
    <div data-controller="reveal">
      <p class="eco-eyebrow">A Word From The Author</p>
      <h2 class="font-display text-[clamp(36px,5vw,64px)] leading-[1.05] mt-6 text-eco-ink">
        Hear it<br>
        <em>from him directly.</em>
      </h2>
      <span class="eco-quote-mark block mt-8">“</span>
      <p class="font-display italic text-[22px] leading-[1.45] text-eco-ink max-w-[520px]">
        He refines ordinary people for Jesus-sized outcomes.
      </p>
      <p class="mt-5 font-mono text-[10px] tracking-[0.22em] uppercase text-eco-ink-soft">— Volume One</p>
    </div>
  </div>
</section>

<%# ─── 06 · VOLUMES (olive-deep, brighter — Andrew's note) ─────────────── %>
<section id="volumes" data-rail-label="Volumes" class="bg-eco-volumes-section relative" style="padding: 110px 0 130px;">
  <div class="max-w-[1240px] mx-auto px-6 md:px-14">
    <p class="eco-eyebrow light">02 — 2 Volumes</p>
    <h2 class="font-display text-[clamp(48px,7vw,78px)] leading-[1] mt-4 text-eco-cream">
      The Two<br><em>Volumes.</em>
    </h2>

    <div class="eco-volumes-row">
      <% [
        { key: :one, num: "1", image: "/source-assets/volume-1.jpg", slug: "the-system-or-the-ecosystem-volume-one"  },
        { key: :two, num: "2", image: "/source-assets/volume-2.jpg", slug: "the-system-or-the-ecosystem-volume-two" },
      ].each do |vol| %>
        <div class="eco-volume-card">
          <%= link_to book_path(vol[:slug]), class: "eco-book-frame" do %>
            <img src="<%= vol[:image] %>"
                 alt="<%= t("home.volumes.#{vol[:key]}") %>"
                 loading="lazy"
                 decoding="async">
          <% end %>
          <p class="eco-volume-blurb">
            <%= t("home.subhead").to_s.split(/[—,]/).first.to_s.strip %>
          </p>
          <%= link_to book_path(vol[:slug]), class: "eco-volume-readmore" do %>
            <span><%= t("home.volumes.read_more", default: "Read more") %></span>
            <span aria-hidden="true">→</span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# ─── 07 · FAITH, REWILDED (paper) ─────────────────────────────────────── %>
<section id="pillars" data-rail-label="Pillars" class="relative" style="background: var(--color-eco-paper); padding: 110px 0;">
  <div class="max-w-[1240px] mx-auto px-6 md:px-14">
    <div class="text-center max-w-2xl mx-auto mb-14" data-controller="reveal">
      <p class="eco-eyebrow center">06 — Faith Rewilded</p>
      <h2 class="font-display text-[clamp(40px,7vw,80px)] leading-[0.98] mt-5 text-eco-ink">
        Faith,<br><em>Rewilded.</em>
      </h2>
    </div>

    <div class="eco-pillar-grid">
      <% [
        { key: "one",   num: "01", cap: "Roots",   title: "Living Roots", body: "Down to the original text — not free-text editing." },
        { key: "two",   num: "02", cap: "Canopy",  title: "Open Canopy",  body: "Light cuts through where structure is symbolic." },
        { key: "three", num: "03", cap: "Order",   title: "Wild Order",   body: "There is deep, intentional intent." },
        { key: "four",  num: "04", cap: "Air",     title: "Mutual Air",   body: "What we breathe in, and breathe out is." },
      ].each_with_index do |p, i| %>
        <article class="eco-pillar-card" data-controller="reveal" style="transition-delay: <%= i * 80 %>ms">
          <div class="img">
            <img src="<%= pillar_images[p[:key]] %>" alt="<%= p[:title] %>" loading="lazy">
            <span class="cap"><%= p[:num] %> / <%= p[:cap] %></span>
          </div>
          <div class="body">
            <h4><%= p[:title] %></h4>
            <p><%= p[:body] %></p>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>

<%# ─── 08 · PULL QUOTE (forest) ────────────────────────────────────────── %>
<section id="quote" data-rail-label="Pull Quote" class="eco-pullquote relative">
  <div class="max-w-[1240px] mx-auto px-6 md:px-14">
    <span class="mark">“</span>
    <h2 data-controller="reveal">
      Religion is typically about a club, a vibe, and rules — <em>Jesus came to blow that up.</em>
    </h2>
    <p class="mt-10 font-mono text-[10px] tracking-[0.22em] uppercase opacity-70">From Volume One</p>
  </div>
</section>

<%# ─── 09 · REVIEWS — They read. Then they wrote back. ─────────────────── %>
<%= render "shared/testimonial_wall" %>

<%# ─── 10 · FREE CTA (forest with sunlit horizon photo) ────────────────── %>
<section id="free" data-rail-label="Get the Books" class="eco-free-cta relative">
  <%# Sunrise/horizon landscape — brighter so sun rays come through %>
  <div class="absolute inset-0 z-0"
       style="background-image: url('<%= cta_image %>'); background-size: cover; background-position: center;"></div>
  <div class="absolute inset-0 z-0"
       style="background: linear-gradient(180deg, rgba(40,52,32,0.62) 0%, rgba(40,52,32,0.32) 50%, rgba(40,52,32,0.72) 100%);"></div>

  <div class="inner relative z-10" data-controller="reveal">
    <span class="eco-pill-eyebrow">✦ 100% Free · No Strings ✦</span>
    <h2>
      Get the books, free, in<br>your hands.
    </h2>
    <p class="sub">100% free hardcopies. Worldwide shipping. No strings.</p>
    <%= link_to t("nav.request"), request_free_copy_path, class: "eco-btn-sage", data: { controller: "magnetic" } %>
  </div>
</section>
